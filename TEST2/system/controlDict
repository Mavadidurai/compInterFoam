libs
(
    "libfluidThermophysicalModels.so"
    "libcompressibleTransportModels.so"
);
// Clean monitoring functions
functions
{
    // Mid-plane visualization (optional)
    midPlaneVTK
    {
        type            surfaces;
        libs            ("libsampling.so");
        writeControl    writeTime;
        writeInterval   1;
        surfaceFormat   vtk;
        fields          (alpha.metal Tl Te T p_rgh U);

        surfaces
        (
            midPlane
            {
                type                cuttingPlane;
                planeType           pointAndNormal;
                pointAndNormalDict
                {
                    point   (25e-6 2.00357e-05 5e-6);
                    normal  (0 1 0);
                }
                interpolate         true;
            }
        );
    }
        // Track jet velocity and position
    jetProbes
    {
        type            probes;
        libs            ("libsampling.so");
        enabled         true;
        writeControl    timeStep;
        writeInterval   100;
        fields          (U alpha.metal T Tl p_rgh);

        // Probe locations along expected jet path (Y-axis)
        probeLocations
        (
            (25e-6 20.00e-6  5e-6)   // Ti surface
            (25e-6 19.00e-6  5e-6)   // 1 μm into air
            (25e-6 18.00e-6  5e-6)   // 2 μm
            (25e-6 16.00e-6  5e-6)   // 4 μm
            (25e-6 14.00e-6  5e-6)   // 6 μm
            (25e-6 12.00e-6  5e-6)   // 8 μm (mid gap)
            (25e-6 10.00e-6  5e-6)   // 10 μm
            (25e-6  8.50e-6  5e-6)   // Near substrate
        );
    }

    // Monitor maximum values
    fieldMinMax
    {
        type            fieldMinMax;
        libs            ("libfieldFunctionObjects.so");
        enabled         true;
        writeControl    timeStep;
        writeInterval   10;

        fields
        (
            U
            alpha.metal
            Tl
            Te
            p_rgh
        );
    }
}

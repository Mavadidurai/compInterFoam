libs
(
    "libfluidThermophysicalModels.so"
    "libcompressibleTransportModels.so"
    "libtwoPhaseProperties.so"
    "libinterfaceProperties.so"
    "libfvOptions.so"
    "libsampling.so"
    "libfieldFunctionObjects.so"
);

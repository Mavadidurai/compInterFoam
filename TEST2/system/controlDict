FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     compInterFoam;

startFrom       latestTime;
startTime       0;
stopAt          endTime;
endTime         2e-10;           // Observation window through plume relaxation

deltaT          1e-15;         // Base time step (1 fs)
adjustTimeStep  yes;           // ENABLE adaptive time stepping
maxCo           0.2;          // Relaxed slightly to avoid needless clipping
thermalFluxRelax 0.15;          // Stronger damping of interface heat flux
maxThermalCourant 0.5;         // Tightened for thermal stability
maxAlphaCo      0.5;          // Allow modest interface Courant growth
maxDeltaT       1e-14;         // Permit limited step growth when flow is calm
minDeltaT       5e-16;         // Keep floor above numerical noise threshold
maxDi           20;  // Limit interface dilation Courant number

// LASER TIMING - shorter pulse, longer observation
laserStartTime      0;
laserEndTime    2e-10;

verbose         true;

// ADAPTIVE OUTPUT - more frequent during active phase, less during cooling
writeControl    adjustableRunTime;
writeInterval   5e-14;         // Start with 0.1 ps intervals to reduce churn
purgeWrite      100;            // Keep more time directories for analysis
writeFormat     ascii;
writePrecision  8;
writeCompression off;
timeFormat      general;
timePrecision   8;             // Increased precision for longer runs
fileHandler     uncollated;

runTimeModifiable yes;
enableLiftProcessTracker true;

// EXTENDED PHASE-CHANGE - longer activation for complete process
phaseChangeCoeffs
{
    model               clausius_clapeyron;  // Not temperature window!
    hf                  [0 2 -2 0 0 0 0] 9.1e6;   // J/kg (Ti vaporisation)
    gasConstant         [0 2 -2 -1 0 0 0] 174;    // J/kg/K (Ti vapor)
    Tsol                [0 0 0 1 0 0 0] 1941;     // K
    Tvap                [0 0 0 1 0 0 0] 3560;     // K
    p_ref               [1 -1 -2 0 0 0 0] 101325; // Pa at Tvap    
    // Kinetic theory parameters
evaporationCoeff       0.05;     // Change from 0.18 back to 0.03-0.06 range
    //momentumAccom       0.18;     // Momentum accommodation
    
    //windowWidth         100;
    dtFloor             1e-15;         // Reduced for precision
    relaxationTime      5e-11;        // Faster response for femtosecond dynamics
    // NOTE: The solver expects maxSource in volumetric units [W/m^3].
    // A 71 nm film would limit the surface heat flux to ~70 W/m^2 if this were large.
    // Set to zero so the volumetric cap is fully disabled and phase change is unconstrained.
    maxSource           [1 -1 -3 0 0 0 0]   1e25;               // No cap; let physical source term dictate heat flux
    minCoefficient      [1 -1 -3 0 0 0 0] 1e6;          // Reduced for gradual cooling
    onlyAboveVapor      false;
    metalFractionCutoff 1e-6;
    // EXTENDED ACTIVATION - through transfer and cooling
    activationTime      ((0 2e-10));  // Active through 400 ps as intended
}

// EXTENDED MASS TRANSFER - through solidification
massTransferCoeffs
{
    tStart  (0);
    tEnd    (2e-10);   // Active through 400 ps
    rateMax 1e11;      // Reduced for later phase stability
}



// Advanced interface capturing - TUNED FOR EXTENDED SIMULATION
useAdvancedInterfaceCapturing  true;
advancedInterfaceCapturing
{
    model               kinetic_theory;  // Not arbitrary scaling!
    stickingCoeff       0.18;
    momentumAccommodationCoeff       0.18;
    recoilMax             5.0e9;      // Limit recoil drive to 5 MPa (Anisimov 1974)
    clampRecoil           false;
    scaleRecoilMax        false;    // Keep cap constant rather than scaling by alpha
    recoilTempOffset      0;        // Trigger recoil once Tl reaches Tvap
    phaseChangeTempOffset 0;      // Match evaporation window to Ti saturation curve
    recoilRelax           0.7;      // Additional damping for stability
    alphaMin              0.01;
    alphaMax              1;
    maxPhysicalTemperature  10000;  // Stay within tabulated Ti properties (~10 kK)
   // pressureScale [1 -1 -2 0 0 0 0] 0.6;  // NEW: Corrects Knight formula
    massRateEps           1e-15;        // Reduced from 1e-8 to detect actual evaporation
        // Physical limits
    maxRecoilPressure   5.0e9;    // 100 MPa absolute max
}
logRecoilSuppression true;

// Temperature clamping - EXTENDED RANGE
enableTClamp    false;
minT            200;           // Allow cooling below room temp
maxT            10000;          // Retained for optional safety if clamp re-enabled

// Two-temperature model properties - OPTIMIZED FOR EXTENDED RUNS
twoTemperatureProperties
{
    
    // Linear electronic heat capacity: Ce = γTe
    Ce
    {
        type        polynomial;
        value       0;
        coeffs
        (
            (0   0)  // Constant term = 0
            (630 1)  // Linear term: Ce = 630 · Te [J/m³/K²]
        );
    }
    
    // Temperature-dependent coupling (Lin & Zhigilei, Phys. Rev. B 77, 2008)
G
{
    type table;
    values
    (
        (300      1.0e18)   // ✓ CORRECT
        (1000     3.0e18)   // ✓ CORRECT
        (2000     6.0e18)   // ✓ CORRECT
        (3000     1.0e19)   // ✓ CORRECT
        (5000     2.0e19)   // ✓ CORRECT
        (7000     3.0e19)
        (10000    5.0e19)   // ✓ CORRECT
        (15000    7.0e19)
        (20000    1.0e20)   // ✓ CORRECT
    );
}
    
    Cl  [1 -1 -2 -1 0 0 0] 2.5e6;
    De  [0  2 -1  0 0 0 0] 1e-4;

    gasMetalExchangeCoeff
    {
        type        kapitza;    // Use acoustic mismatch model
        Z_metal     2.3e7;      // Ti acoustic impedance [Pa·s/m]
        Z_gas       383;        // Ar acoustic impedance [Pa·s/m]
        rho_metal   4500;       // Ti density [kg/m^3]
        rho_gas     1.7;        // Ar density [kg/m^3]
        maxTemperature 0;      // Optional cap [K] (0 => no cap)
    }
    gasMetalCutoffTemperature 3560;
    minMetalFractionForExchange 0.5;
    minGasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 1e6;
    maxGasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 5e8;
    maxGasMetalHeatFlux    5e8;   // Surface heat flux cap [W/m²]
    
    // ✅ ADJUSTED: Allow higher lattice temperatures now that coupling works
    minTe           200;
    maxTe           18000;       // Align electron cap with material data envelope
    maxTl           10000;       // Match lattice clamp to global maxT
    ambientTemperature 300;
    temperatureDifferenceFloor 10.0;                     // Guard against Te/Tl collapse
    
    // ADAPTIVE MICRO-STEPPING
    electronSubCycles        4;
    minElectronSubCycles     2;
    maxElectronSubCycles     20;     // Allow rapid transients
    maxElectronDeltaT        [0 0 1 0 0 0 0] 1e-15;  // Guard rapid transients

    nInnerCouplingSweeps         3;  // More coupling iterations
    innerCouplingResidualTol     1e-4; // Enable convergence check
    
    klHighTThreshold 1000;
    klExponent       0.5;

    metalFractionFloor      1e-9;
    metalFractionCutoff     1e-6;
    metalAmbientBlendWidth  1e-3;
    CvolGasFloor    1e6;  // J/m^3/K floor for gas cells

    energyTolerance         0.02;    // Relaxed for long runs
    energyDiagnostics       false;
    temperatureDiagnostics  false;   // Reduce output volume
    energyAudit             false;
}
enhancedLIFTPhysics
{
    // Phase explosion and spinodal decomposition
    phaseExplosionCoeffs
    {
        enablePhaseExplosion   true;
        T_critical             9500;       // Ti critical temperature [K]
        T_spinodal             8550;       // 0.9 * T_critical [K]
        p_critical             1.2e8;      // Ti critical pressure [Pa]
        tau_explosion          1e-12;      // Explosion timescale [s]
        explosionMultiplier    100.0;      // Mass flux enhancement factor
    }
    // Plasma formation and ionization
    plasmaIonizationCoeffs
    {
        enablePlasmaModel      true;
        ionizationEnergy       1.093e-18;  // Ti: 6.82 eV = 1.093e-18 J
        T_ionization           30000;      // Ionization threshold [K]
        atomicMass             7.95e-26;   // Ti: 47.867 amu [kg]
        atomicNumberDensity    5.68e28;    // Ti: ~5.68e28 atoms/m^3
    }

    // Droplet/jet breakup (Weber number criterion)
    dropletBreakupCoeffs
    {
        enableDropletBreakup   true;
        We_critical            10.0;       // Critical Weber number
        minJetDiameter         1e-7;       // 100 nm [m]
        maxJetDiameter         10e-6;      // 10 μm [m]
        breakupTimeCoeff       1.0;        // Timescale coefficient
    }
}

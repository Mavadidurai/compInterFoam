FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      decomposeParDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// OPTIMIZED DECOMPOSITION FOR TEST2 CASE
// =======================================
// Mesh: 80 (X) × 400 (Z) × 158 (Y) = 5,056,000 cells
// Cores: 16 → ~316,000 cells/core
//
// Strategy: Hierarchical decomposition (4, 4, 1)
//   - X: 80/4 = 20 cells per subdomain
//   - Z: 400/4 = 100 cells per subdomain
//   - Y: 158/1 = 158 cells per subdomain (PRESERVE layer structure)
//
// Benefits:
//   1. Preserves substrate/air/Ti interfaces (no splitting in Y)
//   2. Balanced cubic subdomains → minimal inter-processor communication
//   3. Predictable load balancing for structured mesh
//   4. Order xyz: decompose X first, then Z, then Y

numberOfSubdomains 16;

method          hierarchical;

hierarchicalCoeffs
{
    n           (4 4 1);    // X, Z, Y decomposition
    delta       0.001;      // Cell skew tolerance
    order       xyz;        // Decomposition order
}

// Preserve patches and cyclic boundaries
distributed     no;
roots           ();


// OPTIMIZED DECOMPOSITION FOR TEST2 CASE - LOCAL PC (6 CORES)
// =============================================================
// Mesh: 80 (X) × 400 (Z) × 158 (Y) = 5,056,000 cells
// Target: 6-core laptop (physical cores, e.g., Intel i7-9750H)
// Cores: 6 → ~843,000 cells/core
//
// Strategy: Hierarchical decomposition (2, 3, 1)
//   - X: 80/2 = 40 cells per subdomain
//   - Z: 400/3 ≈ 133 cells per subdomain
//   - Y: 158/1 = 158 cells per subdomain (PRESERVE layer structure)
//
// Physical subdomain size: ~25 μm × 3.33 μm × 20.07 μm
//
// Benefits:
//   1. Preserves substrate/air/Ti interfaces (no splitting in Y)
//   2. Uses physical cores (better thermal management)
//   3. Balanced decomposition along X and Z directions
//   4. Subdomain: 40×133×158 = 842,400 cells (well-balanced load)

numberOfSubdomains 6;

method          hierarchical;

hierarchicalCoeffs
{
    n           (2 3 1);    // X, Z, Y decomposition
    delta       0.001;      // Cell skew tolerance
    order       xyz;        // Decomposition order
}

// Preserve patches and cyclic boundaries
distributed     no;
roots           ();


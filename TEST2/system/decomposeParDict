// OPTIMIZED DECOMPOSITION FOR TEST2 CASE - LOCAL PC
// ==================================================
// Mesh: 80 (X) × 400 (Z) × 158 (Y) = 5,056,000 cells
// Target: 6-core/12-thread laptop (e.g., Intel i7-9750H)
// Cores: 12 → ~421,000 cells/core (optimal for HyperThreading)
//
// Strategy: Hierarchical decomposition (3, 4, 1)
//   - X: 80/3 ≈ 27 cells per subdomain
//   - Z: 400/4 = 100 cells per subdomain
//   - Y: 158/1 = 158 cells per subdomain (PRESERVE layer structure)
//
// Benefits:
//   1. Preserves substrate/air/Ti interfaces (no splitting in Y)
//   2. Utilizes all 12 threads efficiently
//   3. Balanced subdomains → minimal inter-processor communication
//   4. Optimized for local PC performance (not server)

numberOfSubdomains 12;

method          hierarchical;

hierarchicalCoeffs
{
    n           (3 4 1);    // X, Z, Y decomposition
    delta       0.001;      // Cell skew tolerance
    order       xyz;        // Decomposition order
}

// Preserve patches and cyclic boundaries
distributed     no;
roots           ();


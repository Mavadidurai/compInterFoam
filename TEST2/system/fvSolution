FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "alpha.*"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-08;
        relTol          0.0;
        maxIter         100;
        minIter         3;     // Force at least 1 iteration

        nAlphaCorr      2;              // Keep at 1
        nAlphaSubCycles 2;              // Increased to stabilise transport
        cAlpha          2.0;            // Softer compression to avoid overshoot
        icAlpha         0;
        scAlpha         0;
        compressionLimiter 0.50;         // Caps phic relative to |phi|
        MULESCorr       true;
        nLimiterIter    3;
        alphaApplyPrevCorr true;
        sharpeningScheme standard;
        thinFilmCoeff   0.0;
    }

    p_rgh
    {
        solver          GAMG;
        smoother        GaussSeidel;
        tolerance       1e-6;
        relTol          0.001;
        maxIter         200;
        nPreSweeps      1;
        nPostSweeps     3;
        cacheAgglomeration true;
        nCellsInCoarsestLevel 20;
        agglomerator    faceAreaPair;
        mergeLevels     2;
        relaxationFactor 0.6;
    }

    p_rghFinal
    {
        $p_rgh;
        tolerance   1e-8;
        relTol      0;
    }
    
    "U.*"
   {
            solver      smoothSolver;
            smoother    symGaussSeidel;
            nSweeps     2;
            tolerance   1e-06;
            relTol      0.1;
            maxIter     200;
    }

    T
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        nSweeps         6;
        tolerance       1e-6;
        relTol          0.001;             // Tightened relative convergence
        maxIter         50;             // Increased iteration limit
        minIter         3;                // Ensure minimum work
    }

        Te
        {
            $T;
            tolerance       1e-8;
            relTol          0;
        }

        Tl
        {
            $T;
        tolerance       1e-6;
        relTol          1e-4;
        }
}

PIMPLE
{
    momentumPredictor           true;
    nOuterCorrectors            10;           // REDUCE: was 2 (emergency mode)
    nCorrectors                 8;
    nNonOrthogonalCorrectors    3;

    outerCorrectorResidualControl
    {
        "(U|p_rgh)"  { tolerance 1e-4;  relTol 0.1; }
    }
    
    residualControl
    {
        "alpha.*" { tolerance 1e-7;  relTol 0.0; }  // Relaxed from 1e-8
        p_rgh     { tolerance 1e-4;  relTol 0.05; }  // Relaxed for stability
        U         { tolerance 1e-3;  relTol 0.1; }   // Relaxed from 1e-4
        Te        { tolerance 1e-6;  relTol 0.0;  }  // Relaxed from 1e-8
        Tl        { tolerance 1e-6;  relTol 0.0;  }  // Relaxed from 1e-8
        T         { tolerance 1e-6;  relTol 0.05;  } // Relaxed from 1e-7

    }
    
    p_rghRefCell                0;
    p_rghRefValue               101325;
}

relaxationFactors
{
    fields
    {
        p_rgh           0.3;
        "alpha.*"       0.5;
    }
    equations
    {
        U               0.7;
        T               0.2;
        Te              0.4;
        Tl              0.4;
        "alpha.*"       0.5;
        ".*Final"       0.8;
    }
}

// Pressure relaxation control
targetResP  0.05;

compInterFoamCoeffs
{
    maxReasonableVelocity  1000;
    maxVelocity            0;
    defaultMetalDensity    4500;        
    defaultAirDensity      1.2;         
    maxInitialResidual     10;          // REDUCE: was 1e3
    maxPressureGradient    1e16;
    // Interface clamp settings
    enableAlphaClamp  false;
    minAlpha          0.001;
    maxAlpha          0.999;

    // Pressure clamp settings - Feinaeugle et al. (80 MPa experimental max)
    pressureClamp      true;
    maxPressure        2.0e8;     // 200 MPa - physical recoil limit
    minPressure       -1.0e7;

    // Density clamp settings
    densityClamp       false;
    maxDensity         10000;
    minDensity         0.5;

    // RAU clamp settings - CRITICAL for stability with extreme density ratios
    enableRAUClamp     false;   // ENABLE to prevent 1/diagonal singularities
    minRAU             1e-8;   // Increased from 1e-10
    maxRAU             1e5;    // Decreased from 1e6
    minRAUf            1e-12;  // Increased from 1e-14
    maxRAUf            1e5;    // Decreased from 1e6

    // Diagonal safety (keep this)
    minUEqnDiag        1e-9;

    // RELAX RESIDUAL TARGETS
    targetResU         0.1;
    targetResP         0.5;
    // Recoil force smoothing to prevent GAMG divergence
    // Reference: Brackbill et al., JCP 100:335 (1992)
    URelaxationFactor      0.3;   // Aggressive U equation relaxation
    pRelaxationFactor      0.2;   // Aggressive p equation relaxation  
    recoilSmoothingFactor  0.8;   // Smooth recoil application over timesteps
}

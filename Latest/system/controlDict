FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     compInterFoam;

startFrom       latestTime;
startTime       0;
stopAt          endTime;
endTime         5e-8;          // 50 ns simulation time

deltaT          6e-13;         // Base time step
adjustTimeStep  no;
maxCo           0.5;
maxAlphaCo      0.5;
maxDeltaT       5e-11;         // Cap at 50 ps
minDeltaT       5e-15;         // Allow reduction to 5 fs

verbose         true;

maxThermalCourant 0.9;

// Output control
writeControl    runTime;
writeInterval   1e-11;          // Write every 10 ns
purgeWrite      10;            // Keep only last 10 time directories
writeFormat     ascii;
writePrecision  8;             // Reduced from 12
writeCompression off;
timeFormat      general;
timePrecision   6;
fileHandler     uncollated;

runTimeModifiable yes;

// Advanced interface capturing
useAdvancedInterfaceCapturing  true;
advancedInterfaceCapturing
{
    pressureScale        1;
    recoilMax            5e6;           // Increased limit
    clampRecoil          true;
    scaleRecoilMax       true;          // Enable interface scaling
    recoilTempOffset     [0 0 0 1 0 0 0] 0;
    phaseChangeTempOffset [0 0 0 1 0 0 0] 0;
    recoilRelax          0.2;
    alphaMin             0.001;
    alphaMax             0.999;
    logRecoilSuppression false;         // Disable verbose recoil logging
}

// Temperature clamping
enableTClamp    true;
minT            250;
maxT            8000;

// Two-temperature model properties
twoTemperatureProperties
{
    Ce   [1 -1 -2 -1 0 0 0] 1.5e6;
    Cl   [1 -1 -2 -1 0 0 0] 2.3e6;
    G    [1 -1 -3 -1 0 0 0] 5e17;
    
    maxElectronDeltaT        6e-13;
    energyTolerance 0.01;
    minTe 300;
    maxTe 15000;
    minTl 300;
    maxTl 15000;
    gasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 1e15;  // Reduced from 3.2e17
    maxGasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 1e17;
    minGasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 0;
    electronSubCycles 10;
}

libs
(
    "libutilityFunctionObjects.so"
    "libfieldFunctionObjects.so"
    "libsampling.so"
);

// Clean monitoring functions
functions
{
    // Main LIFT monitoring - clean output with validation ranges
    liftMonitor
    {
        type            coded;
        libs            ("libutilityFunctionObjects.so");
        name            liftMonitor;
        writeControl    timeStep;
        writeInterval   20;

        codeWrite
        #{
            const scalar t = mesh().time().value();
            const volScalarField& Te = mesh().lookupObject<volScalarField>("Te");
            const volScalarField& Tl = mesh().lookupObject<volScalarField>("Tl");
            const volScalarField& T = mesh().lookupObject<volScalarField>("T");
            const volScalarField& alpha = mesh().lookupObject<volScalarField>("alpha.metal");
            const volScalarField& p = mesh().lookupObject<volScalarField>("p");
            const volVectorField& U = mesh().lookupObject<volVectorField>("U");
            
            // Max temperatures - fix API calls
            const scalar maxTe = gMax(Te);
            const scalar maxTl = gMax(Tl);
            const scalar maxTgas = gMax(T);
            
            // Metal volume - fix API calls
            const scalarField alphaVol = alpha.primitiveField() * mesh().V();
            const scalar metalVol = gSum(alphaVol);
            const scalar metalVolUm3 = metalVol * 1e18; // Convert to μm³
            
            // Pressure peaks - fix API calls
            const scalar maxPressure = gMax(p);
            const scalar minPressure = gMin(p);
            
            // Ejection velocity (max velocity in metal regions)
            scalar maxEjectionVel = 0.0;
            const scalarField& alphaInternal = alpha.primitiveField();
            const vectorField& UInternal = U.primitiveField();
            
            forAll(alphaInternal, cellI)
            {
                if (alphaInternal[cellI] > 0.1) // Metal-rich cells
                {
                    const scalar velMag = mag(UInternal[cellI]);
                    maxEjectionVel = max(maxEjectionVel, velMag);
                }
            }
            
            // Reduce across processors
            reduce(maxEjectionVel, maxOp<scalar>());
            
            // Validation flags
            word teStatus = "OK";
            if (maxTe < 300) teStatus = "LOW";
            else if (maxTe > 15000) teStatus = "HIGH";
            
            word tlStatus = "OK";
            if (maxTl < 300) tlStatus = "LOW";
            else if (maxTl > 8000) tlStatus = "HIGH";
            
            word pStatus = "OK";
            if (maxPressure > 1e9) pStatus = "HIGH";
            else if (maxPressure < 1e3) pStatus = "LOW";
            
            word velStatus = "OK";
            if (maxEjectionVel > 2000) velStatus = "HIGH";
            else if (maxEjectionVel < 0.1 && maxTl > 2000) velStatus = "LOW";
            
            const scalar startT = mesh().time().startTime().value();
            const scalar endT = mesh().time().endTime().value();
            scalar progress = 0.0;
            if (endT > startT)
            {
                progress = (t - startT)/(endT - startT);
                progress = min(max(progress, 0.0), 1.0);
            }

            // Clean output format with validation
            Info<< "LIFT: t=" << t*1e12 << "ps"
                << " progress=" << progress*100 << "%"
                << " Te=" << maxTe << "K[" << teStatus << "]"
                << " Tl=" << maxTl << "K[" << tlStatus << "]"
                << " Tgas=" << maxTgas << "K"
                << " MetalVol=" << metalVolUm3 << "μm³"
                << " Pmax=" << maxPressure/1e6 << "MPa[" << pStatus << "]"
                << " Pmin=" << minPressure/1e6 << "MPa"
                << " Vmax=" << maxEjectionVel << "m/s[" << velStatus << "]" << endl;
                
            // Detailed validation warnings
            if (teStatus != "OK" || tlStatus != "OK" || pStatus != "OK" || velStatus != "OK")
            {
                Info<< "WARNING: Values outside typical LIFT ranges detected!" << endl;
            }
        #};
    }

    // CSV output for post-processing
    csvOutput
    {
        type            coded;
        libs            ("libutilityFunctionObjects.so");
        name            csvOutput;
        writeControl    timeStep;
        writeInterval   10;

        codeWrite
        #{
            static bool headerWritten = false;
            const scalar t = mesh().time().value();
            
            const volScalarField& Te = mesh().lookupObject<volScalarField>("Te");
            const volScalarField& Tl = mesh().lookupObject<volScalarField>("Tl");
            const volScalarField& T = mesh().lookupObject<volScalarField>("T");
            const volScalarField& alpha = mesh().lookupObject<volScalarField>("alpha.metal");
            const volScalarField& p = mesh().lookupObject<volScalarField>("p");
            const volVectorField& U = mesh().lookupObject<volVectorField>("U");
            
            // Fix API calls
            const scalar maxTe = gMax(Te);
            const scalar maxTl = gMax(Tl);
            const scalar maxTgas = gMax(T);
            const scalarField alphaVol = alpha.primitiveField() * mesh().V();
            const scalar metalVol = gSum(alphaVol) * 1e18;
            const scalar maxP = gMax(p);
            const scalar minP = gMin(p);
            
            // Ejection velocity
            scalar maxVel = 0.0;
            const scalarField& alphaInternal = alpha.primitiveField();
            const vectorField& UInternal = U.primitiveField();
            
            forAll(alphaInternal, cellI)
            {
                if (alphaInternal[cellI] > 0.1)
                {
                    maxVel = max(maxVel, mag(UInternal[cellI]));
                }
            }
            reduce(maxVel, maxOp<scalar>());
            
            // Write CSV
            if (Pstream::master())
            {
                OFstream csvFile
                (
                    "liftResults.csv",
                    IOstreamOption::ASCII,
                    IOstreamOption::currentVersion,
                    IOstreamOption::UNCOMPRESSED,
                    IOstreamOption::APPEND
                );
                if (!headerWritten)
                {
                    csvFile << "time_ps,Te_max_K,Tl_max_K,Tgas_max_K,metal_vol_um3,max_pressure_Pa,min_pressure_Pa,max_velocity_ms" << endl;
                    headerWritten = true;
                }
                csvFile << t*1e12 << "," << maxTe << "," << maxTl << "," << maxTgas 
                        << "," << metalVol << "," << maxP << "," << minP << "," << maxVel << endl;
            }
        #};
    }

    // Phase transition milestones
    milestones
    {
        type            coded;
        libs            ("libutilityFunctionObjects.so");
        name            milestones;
        writeControl    timeStep;
        writeInterval   1;

        codeWrite
        #{
            const scalar t = mesh().time().value();
            const volScalarField& Tl = mesh().lookupObject<volScalarField>("Tl");
            const scalar maxTl = gMax(Tl);
            
            static bool meltHit = false;
            static bool vapHit = false;
            
            if (!meltHit && maxTl > 1941.0) // Ti melting point
            {
                Info<< "*** MELTING at t=" << t*1e12 << "ps, Tl=" << maxTl << "K ***" << endl;
                meltHit = true;
            }
            
            if (!vapHit && maxTl > 3560.0) // Ti vaporization
            {
                Info<< "*** VAPORIZATION at t=" << t*1e12 << "ps, Tl=" << maxTl << "K ***" << endl;
                vapHit = true;
            }
        #};
    }

    // Mid-plane visualization (optional)
    midPlaneVTK
    {
        type        sampledSurface;
        libs        ("libsampling.so");
        surfaceType cuttingPlane;
        planeType   pointAndNormal;
        pointAndNormalDict { point (25e-6 0 5e-6); normal (0 1 0); }
        fields      (alpha.metal Tl Te T p_rgh U);
        interpolate true;
        format      vtk;
        writeControl writeTime;
        writeInterval 1;
    }

    // Comprehensive LIFT validation summary
    liftValidation
    {
        type            coded;
        libs            ("libutilityFunctionObjects.so");
        name            liftValidation;
        writeControl    timeStep;
        writeInterval   100;

        codeWrite
        #{
            const scalar t = mesh().time().value();
            const volScalarField& Te = mesh().lookupObject<volScalarField>("Te");
            const volScalarField& Tl = mesh().lookupObject<volScalarField>("Tl");
            const volScalarField& alpha = mesh().lookupObject<volScalarField>("alpha.metal");
            const volScalarField& p = mesh().lookupObject<volScalarField>("p");
            const volVectorField& U = mesh().lookupObject<volVectorField>("U");
            
            const scalar maxTe = gMax(Te);
            const scalar maxTl = gMax(Tl);
            const scalar maxP = gMax(p);
            
            // Calculate metal loss
            const scalarField alphaVol = alpha.primitiveField() * mesh().V();
            const scalar currentMetalVol = gSum(alphaVol) * 1e18; // μm³
            static scalar initialMetalVol = currentMetalVol; // First call
            const scalar metalLoss = (initialMetalVol - currentMetalVol) / initialMetalVol * 100;
            
            // Calculate ejection velocity
            scalar maxVel = 0.0;
            const scalarField& alphaInternal = alpha.primitiveField();
            const vectorField& UInternal = U.primitiveField();
            
            forAll(alphaInternal, cellI)
            {
                if (alphaInternal[cellI] > 0.1)
                {
                    maxVel = max(maxVel, mag(UInternal[cellI]));
                }
            }
            reduce(maxVel, maxOp<scalar>());
            
            Info<< "=== LIFT VALIDATION SUMMARY at t=" << t*1e12 << "ps ===" << endl;
            Info<< "Temperature Assessment:" << endl;
            Info<< "  Te_max: " << maxTe << "K (Expected: 300-15000K)" << endl;
            Info<< "  Tl_max: " << maxTl << "K (Expected: 300-8000K)" << endl;
            Info<< "  Phase: ";
            if (maxTl < 1941) Info<< "SOLID";
            else if (maxTl < 3560) Info<< "LIQUID"; 
            else Info<< "VAPOR";
            Info<< endl;
            
            Info<< "Pressure Assessment:" << endl;
            Info<< "  P_max: " << maxP/1e6 << "MPa (Expected: 0.1-1000MPa)" << endl;
            Info<< "  Status: ";
            if (maxP < 1e5) Info<< "LOW - Check recoil pressure";
            else if (maxP > 1e9) Info<< "HIGH - May indicate instability";
            else Info<< "NORMAL";
            Info<< endl;
            
            Info<< "Dynamics Assessment:" << endl;
            Info<< "  Max velocity: " << maxVel << "m/s (Expected: 1-2000m/s)" << endl;
            Info<< "  Metal loss: " << metalLoss << "% (Expected: 0.1-10%)" << endl;
            Info<< "  Status: ";
            if (maxVel < 1 && maxTl > 2000) Info<< "LOW - Check momentum transfer";
            else if (maxVel > 2000) Info<< "HIGH - Check numerical stability";
            else Info<< "NORMAL";
            Info<< endl;
            
            Info<< "Overall Assessment: ";
            bool isGood = (maxTe > 1000 && maxTe < 15000) && 
                         (maxTl > 1000 && maxTl < 8000) &&
                         (maxP > 1e5 && maxP < 1e9) &&
                         (maxVel > 1 && maxVel < 2000);
            if (isGood) Info<< "SIMULATION ON TRACK";
            else Info<< "CHECK PARAMETERS";
            Info<< endl;
            Info<< "=============================================" << endl;
        #};
    }
}

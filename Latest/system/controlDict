FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     compInterFoam;

startFrom       latestTime;
startTime       0;
stopAt          endTime;
endTime         5e-8;          // 50 ns simulation time

deltaT          6e-13;         // Base time step
adjustTimeStep  yes;
maxCo           0.5;
maxAlphaCo      0.5;
maxDeltaT       5e-11;         // Cap at 50 ps
minDeltaT       5e-15;         // Allow reduction to 5 fs

verbose         false;         // Disable verbose output

maxThermalCourant 0.9;

// Output control
writeControl    runTime;
writeInterval   1e-9;          // Write every 1 ns
purgeWrite      10;            // Keep only last 10 time directories
writeFormat     ascii;
writePrecision  8;             // Reduced from 12
writeCompression off;
timeFormat      general;
timePrecision   6;
fileHandler     uncollated;

runTimeModifiable yes;

// Advanced interface capturing
useAdvancedInterfaceCapturing  true;
advancedInterfaceCapturing
{
    pressureScale        1;
    recoilMax            5e6;           // Increased limit
    clampRecoil          true;
    scaleRecoilMax       true;          // Enable interface scaling
    recoilTempOffset     [0 0 0 1 0 0 0] 0;
    phaseChangeTempOffset [0 0 0 1 0 0 0] 0;
    recoilRelax          0.2;
    alphaMin             0.001;
    alphaMax             0.999;
    logRecoilSuppression false;         // Disable verbose recoil logging
}

// Temperature clamping
enableTClamp    true;
minT            250;
maxT            8000;

// Two-temperature model properties
twoTemperatureProperties
{
    Ce   [1 -1 -2 -1 0 0 0] 1.5e6;
    Cl   [1 -1 -2 -1 0 0 0] 2.3e6;
    G    [1 -1 -3 -1 0 0 0] 5e17;
    
    maxElectronDeltaT        6e-13;
    energyTolerance 0.01;
    minTe 300;
    maxTe 15000;
    minTl 300;
    maxTl 15000;
    gasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 1e15;  // Reduced from 3.2e17
    maxGasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 1e10;
    minGasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 0;
    electronSubCycles 10;
}

libs
(
    "libutilityFunctionObjects.so"
    "libfieldFunctionObjects.so"
    "libsampling.so"
);

// Clean monitoring functions
functions
{
    // Main LIFT monitoring - clean output
    liftMonitor
    {
        type            coded;
        libs            ("libutilityFunctionObjects.so");
        name            liftMonitor;
        writeControl    timeStep;
        writeInterval   20;

        codeWrite
        #{
            const scalar t = mesh().time().value();
            const volScalarField& Te = mesh().lookupObject<volScalarField>("Te");
            const volScalarField& Tl = mesh().lookupObject<volScalarField>("Tl");
            const volScalarField& T = mesh().lookupObject<volScalarField>("T");
            const volScalarField& alpha = mesh().lookupObject<volScalarField>("alpha.metal");
            const volScalarField& p = mesh().lookupObject<volScalarField>("p");
            const volVectorField& U = mesh().lookupObject<volVectorField>("U");
            
            // Max temperatures - fix API calls
            const scalar maxTe = gMax(Te);
            const scalar maxTl = gMax(Tl);
            const scalar maxTgas = gMax(T);
            
            // Metal volume - fix API calls
            const scalarField alphaVol = alpha.primitiveField() * mesh().V();
            const scalar metalVol = gSum(alphaVol);
            const scalar metalVolUm3 = metalVol * 1e18; // Convert to μm³
            
            // Pressure peaks - fix API calls
            const scalar maxPressure = gMax(p);
            const scalar minPressure = gMin(p);
            
            // Ejection velocity (max velocity in metal regions)
            scalar maxEjectionVel = 0.0;
            const scalarField& alphaInternal = alpha.primitiveField();
            const vectorField& UInternal = U.primitiveField();
            
            forAll(alphaInternal, cellI)
            {
                if (alphaInternal[cellI] > 0.1) // Metal-rich cells
                {
                    const scalar velMag = mag(UInternal[cellI]);
                    maxEjectionVel = max(maxEjectionVel, velMag);
                }
            }
            
            // Reduce across processors
            reduce(maxEjectionVel, maxOp<scalar>());
            
            // Clean output format
            Info<< "LIFT: t=" << t*1e12 << "ps"
                << " Te=" << maxTe << "K"
                << " Tl=" << maxTl << "K" 
                << " Tgas=" << maxTgas << "K"
                << " MetalVol=" << metalVolUm3 << "μm³"
                << " Pmax=" << maxPressure/1e6 << "MPa"
                << " Pmin=" << minPressure/1e6 << "MPa"
                << " Vmax=" << maxEjectionVel << "m/s" << endl;
        #};
    }

    // CSV output for post-processing
    csvOutput
    {
        type            coded;
        libs            ("libutilityFunctionObjects.so");
        name            csvOutput;
        writeControl    timeStep;
        writeInterval   10;

        codeWrite
        #{
            static bool headerWritten = false;
            const scalar t = mesh().time().value();
            
            const volScalarField& Te = mesh().lookupObject<volScalarField>("Te");
            const volScalarField& Tl = mesh().lookupObject<volScalarField>("Tl");
            const volScalarField& T = mesh().lookupObject<volScalarField>("T");
            const volScalarField& alpha = mesh().lookupObject<volScalarField>("alpha.metal");
            const volScalarField& p = mesh().lookupObject<volScalarField>("p");
            const volVectorField& U = mesh().lookupObject<volVectorField>("U");
            
            // Fix API calls
            const scalar maxTe = gMax(Te);
            const scalar maxTl = gMax(Tl);
            const scalar maxTgas = gMax(T);
            const scalarField alphaVol = alpha.primitiveField() * mesh().V();
            const scalar metalVol = gSum(alphaVol) * 1e18;
            const scalar maxP = gMax(p);
            const scalar minP = gMin(p);
            
            // Ejection velocity
            scalar maxVel = 0.0;
            const scalarField& alphaInternal = alpha.primitiveField();
            const vectorField& UInternal = U.primitiveField();
            
            forAll(alphaInternal, cellI)
            {
                if (alphaInternal[cellI] > 0.1)
                {
                    maxVel = max(maxVel, mag(UInternal[cellI]));
                }
            }
            reduce(maxVel, maxOp<scalar>());
            
            // Write CSV
            if (Pstream::master())
            {
                OFstream csvFile("liftResults.csv", ios_base::app);
                if (!headerWritten)
                {
                    csvFile << "time_ps,Te_max_K,Tl_max_K,Tgas_max_K,metal_vol_um3,max_pressure_Pa,min_pressure_Pa,max_velocity_ms" << endl;
                    headerWritten = true;
                }
                csvFile << t*1e12 << "," << maxTe << "," << maxTl << "," << maxTgas 
                        << "," << metalVol << "," << maxP << "," << minP << "," << maxVel << endl;
            }
        #};
    }

    // Phase transition milestones
    milestones
    {
        type            coded;
        libs            ("libutilityFunctionObjects.so");
        name            milestones;
        writeControl    timeStep;
        writeInterval   1;

        codeWrite
        #{
            const scalar t = mesh().time().value();
            const volScalarField& Tl = mesh().lookupObject<volScalarField>("Tl");
            const scalar maxTl = gMax(Tl);
            
            static bool meltHit = false;
            static bool vapHit = false;
            
            if (!meltHit && maxTl > 1941.0) // Ti melting point
            {
                Info<< "*** MELTING at t=" << t*1e12 << "ps, Tl=" << maxTl << "K ***" << endl;
                meltHit = true;
            }
            
            if (!vapHit && maxTl > 3560.0) // Ti vaporization
            {
                Info<< "*** VAPORIZATION at t=" << t*1e12 << "ps, Tl=" << maxTl << "K ***" << endl;
                vapHit = true;
            }
        #};
    }

    // Mid-plane visualization (optional)
    midPlaneVTK
    {
        type        sampledSurface;
        libs        ("libsampling.so");
        surfaceType cuttingPlane;
        planeType   pointAndNormal;
        pointAndNormalDict { point (25e-6 0 5e-6); normal (0 1 0); }
        fields      (alpha.metal Tl Te T p_rgh U);
        interpolate true;
        format      vtk;
        writeControl writeTime;
        writeInterval 1;
    }

    // Metal volume tracking (minimal)
    metalVolume
    {
        type         volRegion;
        libs         ("libfieldFunctionObjects.so");
        regionType   all;
        operation    integrate;
        fields       (alpha.metal);
        writeControl writeTime;
        log          false;
    }
}

FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default          localEuler;              // ✓ GOOD - First-order, stable
    ddt(alpha)       localEuler;              // ✓ GOOD - Consistent with alpha equation
    ddt(rho,U)       localEuler;              // ✓ GOOD - Momentum conservation
    ddt(rho)         localEuler;              // ✓ GOOD - Mass conservation
}

gradSchemes
{
    default         Gauss linear;
    grad(U)         cellLimited Gauss linear 0.5;
    grad(alpha)     cellLimited Gauss linear 1;
    grad(Te)        cellLimited Gauss linear 0.5;
    grad(Tl)        cellLimited Gauss linear 0.5;
    // If you have a single-phase gas T field too:
    grad(T)         cellLimited Gauss linear 0.5;
}

divSchemes
{
    default                          Gauss linear;

    // Interface transport - GOOD improvements made
    div(phi,alpha)                   Gauss vanLeer;        // ✓ GOOD change from vanLeer
    div(phir,alpha)                  Gauss interfaceCompression; // REQUIRED: specialised scheme for compression flux
    div(phi,alpha.metal)             Gauss vanLeer;        // ✓ GOOD
    div(phir,alpha.metal)            Gauss interfaceCompression; // REQUIRED: specialised scheme for compression flux
    div(phi,alpha.air)               Gauss vanLeer;        // ✓ GOOD

    // Momentum - could be more conservative
    div(rhoPhi,U)                    Gauss linearUpwind grad(U); // IMPROVE: Add gradient limiting
    
    // Temperature transport - NEEDS IMPROVEMENT for stability
    div(phi,T)                       Gauss upwind;              // More diffusive for stability
    div(phi,Te)                      Gauss upwind;              // More diffusive for stability
    div(phi,Tl)                      Gauss upwind;              // More diffusive for stability
    
    // Pressure gradient - good change
    div(phi,p_rgh)                   Gauss upwind;           // ✓ GOOD change from linear
    div(((rho*nuEff)*dev2(T(grad(U))))) Gauss linear;       // ✓ OK for viscous terms
}
laplacianSchemes
{
    default                          Gauss linear corrected;  // ✓ GOOD

    // Pressure Laplacians - all good
    laplacian((1|A(U)),p_rgh)        Gauss linear corrected;
    laplacian(rAU,p_rgh)             Gauss linear corrected;
    laplacian((1|A(U)),p)            Gauss linear corrected;

    // Momentum diffusion - good
    laplacian(nuEff,U)               Gauss linear corrected;
    laplacian((rho*nuEff),U)         Gauss linear corrected;

    // Temperature diffusion - could add orthogonal correction limiting
    laplacian(alphaEff,T)            Gauss linear limited 0.1;  // Tighter limiter for non-orth
    laplacian(kappaEff,T)            Gauss linear limited 0.1;  // Tighter limiter for non-orth
    laplacian(kappa,T)               Gauss linear limited 0.1;  // Tighter limiter for non-orth

    // Two-temperature model diffusion - CRITICAL for stability
    laplacian(ke,Te)                 Gauss linear limited 0.1;  // Tighter limiter for non-orth
    laplacian(kl,Tl)                 Gauss linear limited 0.1;  // Tighter limiter for non-orth
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}

wallDist
{
    method          meshWave;                          // ✓ GOOD - robust method
}

fluxRequired
{
    default         no;                                // ✓ GOOD
    p_rgh           yes;                               // ✓ REQUIRED
    alpha.metal     yes;                               // ✓ REQUIRED
    alpha.air       yes;                               // ✓ REQUIRED  
    alpha           yes;                               // ✓ REQUIRED
}


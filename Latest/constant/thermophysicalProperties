FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phases (metal air);


sigma           sigma [ 1 0 -2 0 0 0 0 ] 1.64; // surface tension

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState rhoConst;    // any simple EOS is fine here
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie { molWeight 28.97; }
    thermodynamics { Cp 1000; Hf 0; Tref 300; Href 0; }
    transport { mu 1.8e-5; Pr 0.7; }
    equationOfState { rho 1.2; } // not actually used by your metal/air thermos
}

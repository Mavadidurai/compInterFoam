FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      laserProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// Accepted keys for femtosecondLaserModel:
//   peakIntensity       [W/m^2]
//   pulseWidth          [s]
//   wavelength          [m]
//   absorptionCoeff     [1/m]
//   spotSize            [m]
//   pulseEnergy         [J]
//   direction           (vector)
//   focus               (point)
//   scanVelocity        (vector, optional)
//   pulseFrequency      [1/s, optional]
//   pulseDutyCycle      [-, optional]
//   reflectivity        [-]
//   gaussianProfile     [bool]
//   continuousLaser     [bool]
//   laserStartTime      [s]
//   laserEndTime        [s]
//   gasAbsorptionCoeff  [1/m, optional, default 0]
// Parameter checks enforce pulseWidth 10fs–10ps, wavelength 100nm–2µm
// and peakIntensity ≤6e16 W/m^2.
// Gaussian pulse focused in the 71.4 nm donor film (y=8.0–8.0714 µm)
// Domain: x∈[0,50e-6], y∈[0,20e-6], z∈[0,10e-6]
// CORRECTED: Specify exact film thickness to match blockMeshDict geometry
filmThicknessExpected    7.14e-8;    // 71.4 nm (matches y3 - y2 = 20.0714 - 20.0000)

// geometry coupling
gasAbsorptionCoeff 0;     // [1/m] gas absorption (0 disables direct gas heating)

// --- Energy & timing ---
// Tune energy to exceed the Ti melt+vapor energy (~2.6e-8 J absorbed)
// while staying within the solver's 6e16 W/m^2 guard band.
// The solver now scales the pulse-energy check by the fraction of the Gaussian
// spot that falls inside the mesh bounds, so partially clipped beams no longer
// raise false energy mismatch warnings.
pulseEnergy     2.0e-7;          // [J] total energy (≈0.31 J/cm^2 incident fluence)
pulseWidth      2.14e-13;        // [s] 214 fs pulse width
laserStartTime  0;    // [s] delay pulse until after the fluid preconditioning period
laserEndTime    8e-12;    // [s] extend window to capture trailing pulse tail
// --- Spatial Gaussian (match the box center and film depth) ---
spotSize        6.0e-6;         // [m] beam diameter (3 µm 1/e^2 radius)
//peakIntensity   2.76019082275e16;  // W/m^2 (consistent with 200 nJ pulse)
// Put the beam center inside the domain (mid x,z; inside donor film at y≈8.0357 µm)
focus            (25e-6 20.0357e-6 5e-6);
direction       (0 -1 0);

// --- Wavelength / interaction ---
wavelength          3.43e-7;  // [m]

// Absorption
absorptionCoeff     6.0e7;    // [1/m] ≈17 nm optical depth in Ti at 343 nm

// Reflectivity / profile
reflectivity        0.35;
transmission    -1;   // disable override; use reflectivity entry

gaussianProfile     true;

// Optional intensity entry (consistent with pulseEnergy & pulseWidth)
continuousLaser     false;
maxVolumetricSource 1e24;   // [W/m^3] keep limiter above peak volumetric heating
// NOTE: If peakIntensity is specified, it must match the derived value within 5% or
// the solver now aborts, so omit it to accept the computed value when iterating setups.
// ************************************************************************* //

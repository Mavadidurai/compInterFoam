FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default          backward;
    ddt(alpha)       backward;
    ddt(alpha.metal) backward;
    ddt(alpha.air)   backward;
    ddt(rho,U)       backward;
    ddt(rho)         backward;
}

gradSchemes
{
    default         Gauss linear;
    grad(p_rgh)     Gauss linear;
    grad(p)         Gauss linear;
    grad(alpha.metal) Gauss linear;
    grad(alpha.air)   Gauss linear;
    grad(alpha)       Gauss linear;
    grad(U)         Gauss linear;
    grad(T)         Gauss linear;
    grad(Te)        Gauss linear;
    grad(Tl)        Gauss linear;
}

divSchemes
{
    default                     Gauss linear;

    div(phi,alpha)              Gauss vanLeer;
    div(phirb,alpha)            Gauss interfaceCompression;
    div(phir,alpha)             Gauss interfaceCompression;
    div(phi,alpha.metal)        Gauss vanLeer;
    div(phir,alpha.metal)       Gauss interfaceCompression;
    div(phi,alpha.air)          Gauss vanLeer;

    div(rhoPhi,U)               Gauss linearUpwindV grad(U);
    div(phi,U)                  Gauss linearUpwindV grad(U);
    div(phi,p_rgh)              Gauss linear;

    div(phi,T)                  Gauss limitedLinear 1.0;
    div(phi,Te)                 Gauss upwind;
    div(phi,Tl)                 Gauss limitedLinear 1.0;

    div(phi,K)                  Gauss linear;
    div(phi,h)                  Gauss limitedLinear 1.0;
    div(phi,e)                  Gauss limitedLinear 1.0;

    div(((rho*nuEff)*dev2(T(grad(U))))) Gauss linear;
    div((nuEff*dev2(T(grad(U)))))       Gauss linear;

    div(phi,k)                  Gauss limitedLinear 1.0;
    div(phi,epsilon)            Gauss limitedLinear 1.0;
    div(phi,omega)              Gauss limitedLinear 1.0;

    div((alphaEff*grad(T)))     Gauss linear;
    div((ke*grad(Te)))          Gauss linear;
    div((kl*grad(Tl)))          Gauss linear;
}

laplacianSchemes
{
    default                     Gauss linear corrected;

    laplacian((1|A(U)),p_rgh)   Gauss linear corrected;
    laplacian(rAU,p_rgh)        Gauss linear corrected;
    laplacian((1|A(U)),p)       Gauss linear corrected;

    laplacian(nuEff,U)          Gauss linear corrected;
    laplacian((rho*nuEff),U)    Gauss linear corrected;

    laplacian(alphaEff,T)       Gauss linear corrected;
    laplacian(kappaEff,T)       Gauss linear corrected;
    laplacian(kappa,T)          Gauss linear corrected;

    laplacian(ke,Te)            Gauss linear corrected;
    laplacian(kl,Tl)            Gauss linear corrected;

    laplacian(DkEff,k)          Gauss linear corrected;
    laplacian(DepsilonEff,epsilon) Gauss linear corrected;
    laplacian(DomegaEff,omega)  Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
    interpolate(alpha.metal)    linear;
    interpolate(alpha.air)      linear;
    interpolate(alpha)          linear;
    interpolate(rho)            linear;
    interpolate(mu)             linear;
    interpolate(kappa)          linear;
    interpolate(Te)             linear;
    interpolate(Tl)             linear;
    interpolate(ke)             linear;
    interpolate(kl)             linear;
    interpolate((1|A(U)))       linear;
    interpolate(rAU)            linear;
}

snGradSchemes
{
    default         corrected;
    snGrad(p_rgh)   corrected;
    snGrad(p)       corrected;
    snGrad(T)       corrected;
    snGrad(Te)      corrected;
    snGrad(Tl)      corrected;
    snGrad(alpha.metal) corrected;
    snGrad(alpha)   corrected;
}

wallDist
{
    method          meshWave;
}

fluxRequired
{
    default         no;
    p_rgh           yes;
    alpha.metal     yes;
    alpha.air       yes;
    alpha           yes;
}


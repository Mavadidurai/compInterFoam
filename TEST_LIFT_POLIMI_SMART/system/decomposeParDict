// SMART DECOMPOSITION FOR POLIMI HPC
// ===================================
// Mesh: ~4.86M cells
// Strategy: DON'T SPLIT THE THIN FILM IN Y!
//
// We use hierarchical decomposition with ny=1 so each processor
// owns the FULL vertical stack (including the 71.4 nm film).
// This avoids crazy thin-layer communication and maintains
// physics integrity in the film.

// ============================================================================
// CONFIGURATION 1: 128 cores (RECOMMENDED for ~5M cells)
// ============================================================================

numberOfSubdomains 128;

method          hierarchical;

hierarchicalCoeffs
{
    // Split: 32 in X, 1 in Y, 4 in Z
    // = 32 × 1 × 4 = 128 subdomains
    //
    // Each subdomain:
    // - X: 400/32 = 12.5 cells → ~13 cells wide
    // - Y: 486/1 = 486 cells → FULL HEIGHT (includes film!)
    // - Z: 25/4 = 6.25 → ~6 cells deep
    //
    // Load balance: ~38k cells/core

    n           (32 1 4);
    order       xyz;
    delta       0.001;
}

distributed     no;
roots           ();

// ============================================================================
// WHY ny=1 IS CRITICAL
// ============================================================================
//
// The Ti film is only 71.4 nm = 36 cells thick.
// If we split in Y (e.g., ny=4), each subdomain would get ~9 cells of film.
// Problems:
// 1. Processor boundaries cut through the film
// 2. Heat transfer across boundaries is slow
// 3. Phase change at boundaries is tricky
// 4. Interface tracking gets messy
//
// With ny=1:
// - Each processor owns substrate + air + full film
// - No vertical communication needed for film physics
// - Clean phase change and interface dynamics
// - Film acts as continuous layer
//
// Trade-off: More cells per processor in Y, but:
// - We only have 486 cells total in Y (not crazy)
// - Mesh is graded, so top/bottom are cheap
// - Film region is small relative to total
// - X and Z splits give good parallelism


    // Mid-plane visualization (optional)
    midPlaneVTK
    {
        type            surfaces;
        libs            ("libsampling.so");
        writeControl    writeTime;
        writeInterval   1;
        surfaceFormat   vtk;
        fields          (alpha.metal Tl Te T p_rgh U);

        surfaces
        (
            midPlane
            {
                type                cuttingPlane;
                planeType           pointAndNormal;
                pointAndNormalDict
                {
                    point   (25e-6 2.00357e-05 5e-6);
                    normal  (0 1 0);
                }
                interpolate         true;
            }
        );
    }
}

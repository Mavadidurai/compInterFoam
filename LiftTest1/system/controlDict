FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     compInterFoam;

startFrom       latestTime;
startTime       0;
stopAt          endTime;
endTime         5e-10;          // EXTENDED: 1 ns total for complete LIFT process

deltaT          1e-16;         // Base time step (1 fs)
adjustTimeStep  yes;           // ENABLE adaptive time stepping
maxCo           0.02;          // Allow reasonable growth while staying stable
maxAlphaCo      0.005;         // Aggressive interface limit
maxDeltaT       1e-13;         // Cap adaptive growth (1 fs)
minDeltaT       1e-17;         // Minimum 0.01 fs for precision

verbose         true;
thermalFluxRelax 0.3;          // Stronger damping of interface heat flux
maxThermalCourant 0.05;         // Tightened for thermal stability

// ADAPTIVE OUTPUT - more frequent during active phase, less during cooling
writeControl    adjustableRunTime;
writeInterval   1e-14;         // Start with 1 ps intervals
purgeWrite      50;            // Keep more time directories for analysis
writeFormat     ascii;
writePrecision  8;
writeCompression off;
timeFormat      general;
timePrecision   8;             // Increased precision for longer runs
fileHandler     uncollated;

runTimeModifiable yes;
enableLiftProcessTracker true;

// EXTENDED PHASE-CHANGE - longer activation for complete process
phaseChangeCoeffs
{
    model               clausius_clapeyron;  // Not temperature window!
    hf                  [0 2 -2 0 0 0 0] 3.65e5;  // J/kg (Ti)
    Tsol                [0 0 0 1 0 0 0] 1941;     // K
    Tvap                [0 0 0 1 0 0 0] 3560;     // K
    
    // Kinetic theory parameters
    stickingCoeff       0.18;     // Ti evaporation coefficient
    momentumAccom       0.18;     // Momentum accommodation
    
    dtFloor             1e-15;         // Reduced for precision
    relaxationTime      1e-11;        // Faster response for femtosecond dynamics
    maxSource           1e8;          // Allow sufficient heating-driven mass transfer
    minCoefficient      1e6;          // Reduced for gradual cooling
    onlyAboveVapor      true;
    metalFractionCutoff 1e-6;
    // EXTENDED ACTIVATION - through transfer and cooling
    activationTime      ((0 2e-10));  // Active through 400 ps
}

// EXTENDED MASS TRANSFER - through solidification
massTransferCoeffs
{
    tStart  (0);
    tEnd    (2e-10);   // Active through 400 ps
    rateMax 1e11;      // Reduced for later phase stability
}

// LASER TIMING - shorter pulse, longer observation
laserStartTime      0;
laserEndTime    1e-10;

// Advanced interface capturing - TUNED FOR EXTENDED SIMULATION
useAdvancedInterfaceCapturing  true;
advancedInterfaceCapturing
{
    model               kinetic_theory;  // Not arbitrary scaling!
    stickingCoeff       0.18;
    momentumAccom       0.18;
    recoilMax             5e6;
    clampRecoil           true;
    scaleRecoilMax        false;
    recoilTempOffset      100;
    phaseChangeTempOffset 100;
    recoilRelax           0.5;
    alphaMin              0.05;
    alphaMax              0.95;
    maxPhysicalTemperature 5000;
        // Physical limits
    maxRecoilPressure   1e8;    // 100 MPa absolute max
}
logRecoilSuppression true;

// Temperature clamping - EXTENDED RANGE
enableTClamp    true;
minT            200;           // Allow cooling below room temp
maxT            3500;          // Clamp high temperatures for stability

// Two-temperature model properties - OPTIMIZED FOR EXTENDED RUNS
twoTemperatureProperties
{
    // Linear electronic heat capacity: Ce = γTe
    Ce
    {
        type        polynomial;
        value       0;
        coeffs
        (
            (0   0)  // Constant term = 0
            (630 1)  // Linear term: Ce = 630 · Te [J/m³/K²]
        );
    }
    
    // Temperature-dependent coupling
    G
    {
        type        table;
        values
        (
            (300    3e16)
            (1000   4.2e16)
            (2000   4.8e16)
            (3000   5.2e16)
            (5000   6e16)
            (10000  7.5e16)
        );
    }
    
    Cl  [1 -1 -2 -1 0 0 0] 2.5e6;
    De  [0  2 -1  0 0 0 0] 1e-4;

    gasMetalExchangeCoeff
    {
        type        kapitza;    // Use acoustic mismatch model
        Z_metal     2.3e7;      // Ti acoustic impedance [Pa·s/m]
        Z_gas       383;        // Ar acoustic impedance [Pa·s/m]
    }
    minGasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 1e8;
    maxGasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 1e12;
    maxGasMetalHeatFlux    1e11;
    minTe           200;
    maxTe           20000;      // Allow hot electrons
    maxTl           5000;       // Physical melting limit
    ambientTemperature 300;

    // ADAPTIVE MICRO-STEPPING
    electronSubCycles        1;
    minElectronSubCycles     1;
    maxElectronSubCycles     10;     // Allow rapid transients
    maxElectronDeltaT        [0 0 1 0 0 0 0] 1e-15;  // Guard rapid transients

    nInnerCouplingSweeps         2;  // More coupling iterations
    innerCouplingResidualTol     1e-3; // Enable convergence check
    
    klHighTThreshold 1000;
    klExponent       0.5;

    metalFractionFloor      1e-6;
    metalFractionCutoff     1e-6;
    metalAmbientBlendWidth  1e-3;
 // ✅ CRITICAL: Added missing gas volume heat capacity floor
    CvolGasFloor            1e6;     // J/m³/K minimum for gas
    
    energyTolerance         0.05;    // Relaxed for long runs
    energyDiagnostics       true;
    temperatureDiagnostics  true;   // Reduce output volume
    energyAudit             false;
}


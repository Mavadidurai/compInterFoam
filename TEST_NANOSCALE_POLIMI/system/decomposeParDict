FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      decomposeParDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// OPTIMIZED DECOMPOSITION FOR POLIMI HPC CLUSTER
// Ultra-fine nanoscale mesh: ~102 Million cells
// Target: 128-256 cores for optimal performance
//
// Cell distribution:
// - ~800,000 cells/core for 128 cores
// - ~400,000 cells/core for 256 cores
//
// Choose configuration based on available resources

// ============================================================================
// CONFIGURATION 1: 128 cores (RECOMMENDED)
// ============================================================================
numberOfSubdomains 128;

method          hierarchical;

hierarchicalCoeffs
{
    // Decompose: 8 × 4 × 4 = 128 subdomains
    // This gives good aspect ratio and balances the anisotropic mesh
    n           (8 8 2);
    order       xyz;
    delta       0.001;
}


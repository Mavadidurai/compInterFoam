FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    yMax
    {
        type            totalPressure;
        p0              uniform 0;
        value           uniform 0;
    }
    yMin
    {
        type            zeroGradient;
        
    }
    xMin
    {
        type            zeroGradient;
    }
    xMax
    {
        type            totalPressure;
        p0              uniform 0;
        value           uniform 0;
    }
    zMin
    {
        type            zeroGradient;
    }
    zMax
    {
        type            zeroGradient;
    }
}


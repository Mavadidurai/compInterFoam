FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      p_rgh;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    yMax
    {
        type fixedFluxPressure; 
        value uniform 0;
    }
    yMin
    {
        type fixedFluxPressure; 
        value uniform 0;
        
    }
    xMin
    {
        type fixedFluxPressure; 
        value uniform 0;
    }
    xMax
    {
        type fixedFluxPressure;
         value uniform 0;
    }
    zMin
    {
        type            zeroGradient;
    }
    zMax
    {
       type                fixedFluxPressure;   // or totalPressure if already consistent
       value               uniform 0;
    }
}


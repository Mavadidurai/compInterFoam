#!/bin/sh
cd "${0%/*}" || exit                                # Run from this directory
. ${WM_PROJECT_DIR:?}/bin/tools/CleanFunctions      # Tutorial clean functions
#------------------------------------------------------------------------------

# Extract startTime value from controlDict
startTime=$(grep -E "^\s*startTime\s+" system/controlDict | awk '{print $2}' | tr -d ';')
if [ -z "$startTime" ]; then
    startTime="0"
fi
echo "Using startTime: $startTime"

cleanCase
cleanSamples

# Remove decomposed directories
rm -rf processor*

# Remove post-processing results
rm -rf postProcessing

# Remove mesh and field backups
rm -rf 0
rm -rf $startTime
rm -rf *.obj

# Remove logs
rm -f log.*

# Copy 0.orig to correct start directory
[ -d "$startTime" ] || cp -r 0.orig "$startTime"

# Copy 0.orig to 0 if needed
[ -d 0 ] || cp -r 0.orig 0

#------------------------------------------------------------------------------

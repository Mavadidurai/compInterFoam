FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convertToMeters 1e-6; // coordinates in micrometers

vertices
(
    (0   0   0)   // 0  y=0   z=0
    (50  0   0)   // 1  y=0   z=0
    (50  8   0)   // 2  y=8µm z=0
    (0   8   0)   // 3  y=8µm z=0
    (0   10  0)   // 4  y=10µm z=0
    (50  10  0)   // 5  y=10µm z=0
    (50  20  0)   // 6  y=20µm z=0
    (0   20  0)   // 7  y=20µm z=0
    (0   0   10)  // 8  y=0   z=10µm
    (50  0   10)  // 9  y=0   z=10µm
    (50  8   10)  // 10 y=8µm z=10µm
    (0   8   10)  // 11 y=8µm z=10µm
    (0   10  10)  // 12 y=10µm z=10µm
    (50  10  10)  // 13 y=10µm z=10µm
    (50  20  10)  // 14 y=20µm z=10µm
    (0   20  10)  // 15 y=20µm z=10µm
);

blocks
(
    // substrate: 0–8 µm
    hex (0 1 2 3 8 9 10 11)   (25 80 10) simpleGrading (1 0.2 1)
    // metal film: 8–10 µm
    hex (3 2 5 4 11 10 13 12) (25 20 10) simpleGrading (1 20 1)
    // air gap: 10–20 µm
    hex (4 5 6 7 12 13 14 15) (25 100 10) simpleGrading (1 5 1)
);

edges ();

boundary
(
    zMax		//top
    {
        type wall;
        faces
        (
            (8 9 10 11)
            (11 10 13 12)
            (12 13 14 15)
        );
    }
    zMin		//bottom
    {
        type wall;
        faces
        (
            (0 1 2 3)
            (3 2 5 4)
            (4 5 6 7)
        );
    }
    xMin		//inlet
    {
        type wall;
        faces
        (
            (0 3 11 8)
            (3 4 12 11)
            (4 7 15 12)
        );
    }
    xMax		//outlet
    {
        type wall;
        faces
        (
            (1 2 10 9)
            (2 5 13 10)
            (5 6 14 13)
        );
    }
    yMin		//front
    {
        type wall;
        faces ((0 1 9 8));         // y=0 plane
    }
    yMax		//back
    {
        type wall;
        faces ((7 6 14 15));       // y=20 μm plane
    }
);

mergePatchPairs ();

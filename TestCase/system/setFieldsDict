// Only numbers adjusted; no factors/models changed.
// Update the BOX LIMITS below to match your mesh (in meters).
// Coordinate convention: X,Z lateral, Y vertical (gravity in -Y).

FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      setFieldsDict;
}

// NOTE: No #calc / #codeStream used.
// Edit the numeric values below to match your case if needed.

// --- Domain sizes (must match blockMesh) ---
/* Lateral extents: */  // X and Z
// Lx = 4.0e-5 m (40 µm)
// Lz = 4.0e-5 m (40 µm)

// --- Layering along Y ---
/* substrate: y in [0.0,       8.0e-6]    m */
/* metal:     y in [8.0e-6,    8.0714e-6] m */  // 71.4 nm thick
/* air:       y in [8.0714e-6, 3.0e-5]    m */

// --- Initial conditions ---
/* Temperatures: */  // K
// T0 = 500; Te0 = 500; Tl0 = 500;
/* Velocity: */     // m/s
// U0 = (0 0 0);
/* Pressure: */
// p_rgh0 = 0;

// --- Phase fractions ---
/* alpha.metal in metal layer = 1, elsewhere 0 */

defaultFieldValues
(
    volScalarFieldValue T           500
    volScalarFieldValue Te          500
    volScalarFieldValue Tl          500
    volVectorFieldValue U         (0 0 0)
    volScalarFieldValue p_rgh     0

    // default to air everywhere; regions below will overwrite
    volScalarFieldValue alpha.metal 0
    volScalarFieldValue alpha.air   1
);

// Regions (explicit numeric boxes)
regions
(
    // Heat sink:  y in [0, 8 µm]
    boxToCell
    {
        box (0       0.0       0)
            (5.0e-05 8.0e-06   1.0e-05);
        fieldValues
        (
            volScalarFieldValue alpha.metal 1
            volScalarFieldValue alpha.air   0
            volScalarFieldValue T           500
            volScalarFieldValue Te          500
            volScalarFieldValue Tl          500

        );
    }

    // Metal thin film: y in [8 µm, 8.0714 µm] (~71.4 nm)
    boxToCell
    {
        box (0       8.0e-06    0)
            (5.0e-05 8.0714e-06 1.0e-05);
        fieldValues
        (
            volScalarFieldValue alpha.metal 1
            volScalarFieldValue alpha.air   0
            volScalarFieldValue T           500
            volScalarFieldValue Te          500
            volScalarFieldValue Tl          500

        );
    }

    // Air: y in [8.0714 µm, 30 µm]

    boxToCell
    {
        box (0       8.0714e-06 0)
            (5.0e-05 3.0e-05   1.0e-05);
        fieldValues
        (
            volScalarFieldValue alpha.metal 0
            volScalarFieldValue alpha.air   1
            volScalarFieldValue T           500
            volScalarFieldValue Te          500
            volScalarFieldValue Tl          500
  
        );
    }
);

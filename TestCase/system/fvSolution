FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "alpha.*"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-12;
        relTol          0.0;
        maxIter         100;
        minIter         2;

        nAlphaCorr      3;              // CORRECTED: Reduced from 5 for sharper interface
        nAlphaSubCycles 3;              // CORRECTED: Reduced from 5
        cAlpha          2.0;            // CORRECTED: Increased from 1.0 to sharpen interface
        icAlpha         0;
        scAlpha         0;
        compressionLimiter 0.5;         // CORRECTED: Reduced from 1.0 for less dissipation
        MULESCorr       true;
        nLimiterIter    3;              // CORRECTED: Reduced from 5
        alphaApplyPrevCorr true;
        sharpeningScheme standard;
        thinFilmCoeff   0.0;
    }

    p_rgh
    {
        solver          GAMG;
        smoother        DICGaussSeidel;
        tolerance       1e-6;
        relTol          0.05;
        maxIter         50;
        nPreSweeps      0;
        nPostSweeps     2;
        cacheAgglomeration true;
        nCellsInCoarsestLevel 20;
        agglomerator    faceAreaPair;
        mergeLevels     2;
        relaxationFactor 0.7;
    }

    p_rghFinal
    {
        $p_rgh;
        tolerance   1e-8;
        relTol      0;
    }
    
    "U.*"
   {
            solver      smoothSolver;
            smoother    symGaussSeidel;
            nSweeps     2;
            tolerance   1e-06;
            relTol      0.5;
            maxIter     200;
            minIter     1;
    }

    T
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        nSweeps         6;
        tolerance       1e-8;
        relTol          0.01;             // Allow 1% relative convergence
        maxIter         1000;             // Increased iteration limit
        minIter         3;                // Ensure minimum work
    }

    TFinal
    {
        $T;
        tolerance       1e-9;
        relTol          0;
        maxIter         1000;
    }

    Te
    {
         solver          smoothSolver;
        smoother        symGaussSeidel;
        nSweeps         6;
        tolerance       1e-8;
        relTol          0;
        maxIter         1000;
        minIter         3;
    }

    Tl
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        nSweeps         6;
        tolerance       1e-8;
        relTol          0;
        maxIter         1000;
        minIter         3;
    }
}

PIMPLE
{
    momentumPredictor           true;
    nOuterCorrectors            20;           // INCREASED for better pressure-velocity coupling
    nCorrectors                 5;            // INCREASED from 3 for tighter p-U coupling
    nNonOrthogonalCorrectors    3;            // INCREASED from 2 for better pressure convergence

    // Sub-iteration for momentum predictor (helps with extreme recoil)
    momentumPredictorIterations 2;

    residualControl
    {
        "alpha.*" { tolerance 1e-10; relTol 0.0; }    // Tighter for accurate interface
        p_rgh     { tolerance 1e-5;  relTol 0.01; }   // Tighter for fast jets
        U         { tolerance 1e-6;  relTol 0.005; }  // Tighter for accurate velocities
        Te        { tolerance 5e-9;  relTol 0.0;  }   // thermal is stiff; be stricter
        Tl        { tolerance 5e-9;  relTol 0.0;  }
        T         { tolerance 1e-9;  relTol 0.005;  } // Tighter for temperature accuracy
    }

    p_rghRefCell                0;
    p_rghRefValue               101325;
}

relaxationFactors
{
    fields
    {
        p_rgh           0.3;
        "alpha.*"       0.5;
    }
    equations
    {
        U               0.5;
        T               0.5;
        Te              0.5;
        Tl              0.5;
        "alpha.*"       0.5;
        ".*Final"       0.7;
    }
}

// Pressure relaxation control
targetResP  0.5;

compInterFoamCoeffs
{
    // CRITICAL FIX: Remove artificial velocity clamping
    maxVelocity            0;         // DISABLED: was causing uniform 500 m/s field
    maxReasonableVelocity  800;       // Keep for validation warnings only
    // NOTE: Feinaeugle et al. (Appl. Surf. Sci. 418, 2017) report fs-LIFT recoil
    // peaks around 70–80 MPa.  Resolving that across the 71.4 nm film requires
    // |∇p| ≈ 1×10^15 Pa/m, so lift the limiter accordingly.
    
    maxPressureGradient    1e16;
    maxUEqnVelocity        1000;  // Hard cap at 1000 m/s
    defaultMetalDensity    4500;
    defaultAirDensity      1.2;
    maxInitialResidual     10;

    // Interface clamp settings
    enableAlphaClamp  false;
    minAlpha          0.001;
    maxAlpha          0.999;

    // CRITICAL FIX: Disable pressure clamp to allow full recoil dynamics
    // Jetting requires 5-15 GPa recoil pressure, which was previously capped at 200 MPa
    pressureClamp      false;
    maxPressure        2.0e8;
    minPressure       0;

    // Density clamp settings
    densityClamp       false;
    maxDensity         10000;
    minDensity         0.5;

    // RAU clamp settings  
    enableRAUClamp     false;
    minRAU             1e-10;
    maxRAU             1e6;
    minRAUf            1e-14;
    maxRAUf            1e6;

    // Diagonal safety (keep this)
    minUEqnDiag        1e-9;

    // RELAX RESIDUAL TARGETS
    targetResU         0.1;
    targetResP         0.5;
}

FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      topoSetDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

actions
(
    {
        name        substrate;
        type        cellSet;
        action      new;
        source      boxToCell;
        sourceInfo
        {
            box (0 0 0) (50 8 10);
        }
    }
    {
        name        substrate;
        type        cellZoneSet;
        action      new;
        source      setToCellZone;
        sourceInfo
        {
            set substrate;
        }
    }
);


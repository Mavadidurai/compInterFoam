FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     compInterFoam;

startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         5e-8;               // extend into tens of nanoseconds

deltaT          1e-15;
adjustTimeStep  yes;
maxCo           0.2;
maxAlphaCo      0.2;
maxDeltaT       5e-12;            // allow growth after pulse
// optional runtime output verbosity
verbose         false;
writeControl    runTime;
writeInterval   1e-9;              // write every 1 ns of simulated time
purgeWrite      100;               // retain a broader history
writeFormat     binary;
writePrecision  10;
writeCompression on;
timeFormat      general;
timePrecision   12;
fileHandler     collated;

runTimeModifiable yes;

dynamicFvMesh   dynamicRefineFvMesh;

dynamicRefineFvMeshCoeffs
{
    field            alpha.metal;
    refineInterval   1;
    lowerRefineLevel 0.05;
    upperRefineLevel 0.98;
    unrefineLevel    0.001;
    nBufferLayers    1;
    maxRefinement    3;
    maxCells         4000000;
    correctFluxes    (phi none);
}
// solver switches (kept as in your file)
useAdvancedInterfaceCapturing  true;
advancedInterfaceCapturing
{
    // thresholds (must match your transportProperties metal)
    meltingTemperature   1941;     // K
    vaporTemperature     3200;     // K (onset of strong recoil)

    // strength & stability
    pressureScale        2e4;      // nondim scale used in your model
    recoilMax            5e7;      // Pa cap (was too low by default)
    recoilUpdateInterval 1;        // evaluate every step
    alphaBounds
    {
        alphaMin 0.001;
        alphaMax 0.999;
    }
}
// rAUf clamp range used in pEqn.H
enableRAUfClamp   true;
minRAUf           1e-12;
maxRAUf           1e8;

// pressure clamp used in pEqn.H
pressureClamp     true;
minPressure       1e2;     // Pa
maxPressure       5e8;     // Pa  (allow tens/hundreds of MPa if needed)

// adaptive relaxation used in pEqn.H
relaxP            0.2;
targetResP        0.05;

// (keep your existing maxCo/maxAlphaCo)

enableTClamp                   true;
minT                           250;
maxT                           8000;
// Temperature offset below melting point to activate recoil pressure (K)
recoilTempOffset               100;
pressureClamp                  false;

minPressure                    100;
maxPressure                    1e9;
maxVelocity                    3000;
minRAUf                        1e-12;
maxRAUf                        1e8;

densityClamp                   true;
minDensity                     0.5;
maxDensity                     15000;

twoTemperatureProperties
{
    Ce  2.5e6;
    Cl  3.5e6;
    G   3.0e16;
    energyTol 0.1; // relative energy change tolerance
}

functions
{
    fieldWrite
    {
        type              writeObjects;
        libs              ("libutilityFunctionObjects.so");
        objects           (Q_laser U p_rgh T alpha.metal);
        writeOnExecution  true;
    }

    probesTTM
    {
        type            probes;
        libs            ("libsampling.so");
        fields          (Te Tl T p_rgh U alpha.metal);
        probeLocations  ((0 0 0) (0 0 2e-6) (0 0 10e-6));
        writeControl    timeStep;
        writeInterval   5;       // tighter probes for ultrafast features
    }

    CourantNo
    {
        type CourantNo; libs ("libutilityFunctionObjects.so");
        writeControl timeStep; writeInterval 5;
    }

    fieldMinMax_T
    {
        type fieldMinMax; libs ("libfieldFunctionObjects.so");
        writeControl timeStep; writeInterval 5; fields (T);
    }

    fieldMinMax_alpha
    {
        type fieldMinMax; libs ("libfieldFunctionObjects.so");
        writeControl timeStep; writeInterval 5; fields (alpha.metal);
    }

    
}




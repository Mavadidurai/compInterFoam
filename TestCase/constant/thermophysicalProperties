FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// ✅ ENHANCED: Two-phase system with substrate effects via boundary conditions
phases (metal air);

// ✅ METAL PHASE: Titanium donor film
metal
{
    transportModel  Newtonian;
    nu              nu [ 0 2 -1 0 0 0 0 ] 5e-7;     // Kinematic viscosity
    rho             rho [ 1 -3 0 0 0 0 0 ] 4500;     // Titanium density
}

// ✅ AIR PHASE: Air with substrate region simulation
air
{
    transportModel  Newtonian;
    nu              nu [ 0 2 -1 0 0 0 0 ] 1.48e-5;   // Air kinematic viscosity
    rho             rho [ 1 -3 0 0 0 0 0 ] 1.2;       // Air density
}

// ✅ ENHANCED: Interface properties with substrate effects
sigma           sigma [ 1 0 -2 0 0 0 0 ] 1.5;          // N/m - Metal-air surface tension

// ✅ ENHANCED: Phase change properties for substrate-backed LIFT
meltingTemperature      1941.0;             // K - Titanium melting point
vaporTemperature        3560.0;             // K - Titanium vaporization point
latentHeat              435e3;              // J/kg - Latent heat of fusion

// ✅ NEW: Substrate thermal influence on phase change
substrateThermalEffects
{
    // Enhanced heat conduction due to substrate backing
    thermalConductivityEnhancement  1.5;    // Enhancement factor at interface
    
    // Heat sink effect from substrate
    substrateHeatSink      2.1e6;           // J/m³/K - Substrate volumetric heat capacity
    heatSinkEfficiency     0.8;             // Efficiency of heat transfer to substrate
    
    // Interface thermal resistance
    interfaceThermalResistance  1e-8;       // m²K/W - Substrate/metal interface
}

// ✅ OPTIMIZED: Interface compression for substrate system
cAlpha          0.5;              // Reduced compression for stability
icAlpha         0;                // Isotropic compression (disabled)
scAlpha         0;                // Shear compression (disabled)

// ✅ ENHANCED: Reference conditions with substrate considerations
pRef            100000;                     // Pa - Reference pressure
TRef            300;                        // K - Reference temperature
pMin            pMin [ 1 -1 -2 0 0 0 0 ] 10000;  // Pa - Minimum pressure

// ✅ NEW: Substrate-specific thermophysical properties
substrateProperties
{
    // Glass substrate thermal properties
    density                 2500;           // kg/m³ - Glass density
    specificHeat           840;             // J/kg/K - Glass specific heat
    thermalConductivity    1.3;            // W/m/K - Glass thermal conductivity
    thermalDiffusivity     6.2e-7;         // m²/s - Glass thermal diffusivity
    
    // Optical properties (for laser interaction)
    refractiveIndex        1.52;           // Glass refractive index at 800nm
    absorptionCoefficient  1e-3;           // 1/m - Minimal absorption (transparent)
    transmittance          0.95;           // Fraction transmitted
    
    // Mechanical properties
    expansionCoefficient   9e-6;           // 1/K - Thermal expansion
    bulkModulus           37e9;            // Pa - Bulk modulus
    poissonRatio          0.23;            // Poisson's ratio
}

// ✅ NEW: Temperature-dependent property models
temperatureDependentProperties
{
    // Metal properties variation with temperature
    metalThermalConductivity
    {
        model               polynomial;
        coeffs              (21.9 0.01 -1e-5);  // W/m/K - k = a + bT + cT²
        Tmin                300;                 // K
        Tmax                3000;                // K
    }
    
    // Surface tension temperature dependence
    surfaceTension
    {
        model               linear;
        coeffs              (1.5 -2e-4);        // sigma = a + bT
        Tmin                300;                 // K
        Tmax                2500;                // K
    }
    
    // Viscosity temperature dependence  
    metalViscosity
    {
        model               Arrhenius;
        mu0                 1e-3;               // Pa·s - Reference viscosity
        E                   20000;              // J/mol - Activation energy
        Tref                1941;               // K - Reference temperature
    }
}

// ✅ NEW: LIFT-specific physics parameters
liftPhysics
{
    // Nucleation and bubble formation
    nucleationThreshold     20;             // K - Superheat for nucleation
    bubbleGrowthRate       1.5e6;             // m/s - Bubble expansion rate
    criticalBubbleSize     1e-7;            // m - Critical bubble size

    // Ejection dynamics
    recoilPressureScale    1.5e5;             // Pa - Characteristic recoil pressure
    ejectionEfficiency     0.25;             // Fraction of thermal energy → kinetic energy

    // Droplet formation
    dropletBreakupLength   7e-6;            // m - Characteristic breakup length
    webberNumber           5;                // Critical Weber number for breakup
}

#!/bin/sh
set -eu
self=$(readlink -f "$0")
script_dir=$(dirname "$self")

old_path=$PATH
trimmed_path=
old_ifs=$IFS
IFS=:
for dir in $old_path; do
    if [ "$dir" = "$script_dir" ]; then
        continue
    fi
    if [ -z "$trimmed_path" ]; then
        trimmed_path=$dir
    else
        trimmed_path=$trimmed_path:$dir
    fi
done
IFS=$old_ifs
PATH=$trimmed_path

if command -v wmake >/dev/null 2>&1; then
    real=$(command -v wmake)
    if [ "$real" != "$self" ]; then
        exec "$real" "$@"
    fi
fi
cat <<'EOF_MSG'
Error: OpenFOAM's wmake command is not available on your PATH.
This solver must be compiled inside an OpenFOAM environment.
Please source the appropriate OpenFOAM bashrc, for example:
    source /opt/openfoam/etc/bashrc
and then rerun:
    wmake
EOF_MSG
exit 127

FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     compInterFoam;

startFrom       latestTime;
startTime       0;
stopAt          endTime;
endTime         2e-9;           // Observation window through plume relaxation

deltaT          1e-13;         // ✅ CORRECTED: Base time step (0.1 ps, matches electron-phonon timescale)
adjustTimeStep  yes;           // ENABLE adaptive time stepping
maxCo           0.05;          // Relaxed slightly to avoid needless clipping
maxAlphaCo      0.01;          // Allow modest interface Courant growth
maxDeltaT       5e-13;         // ✅ CORRECTED: Max 0.5 ps (physically reasonable for lattice dynamics)
minDeltaT       1e-14;         // ✅ CORRECTED: Min 0.01 ps (above numerical noise threshold)

verbose         true;
thermalFluxRelax 0.1;          // Stronger damping of interface heat flux
maxThermalCourant 0.001;         // Tightened for thermal stability

// ADAPTIVE OUTPUT - more frequent during active phase, less during cooling
writeControl    adjustableRunTime;
writeInterval   1e-14;         // Start with 0.1 ps intervals to reduce churn
purgeWrite      100;            // Keep more time directories for analysis
writeFormat     ascii;
writePrecision  8;
writeCompression off;
timeFormat      general;
timePrecision   8;             // Increased precision for longer runs
fileHandler     uncollated;

runTimeModifiable yes;
enableLiftProcessTracker true;

// EXTENDED PHASE-CHANGE - longer activation for complete process
phaseChangeCoeffs
{
    model               clausius_clapeyron;  // Not temperature window!
    hf                  [0 2 -2 0 0 0 0] 9.1e6;   // J/kg (Ti vaporisation)
    gasConstant         [0 2 -2 -1 0 0 0] 174;    // J/kg/K (Ti vapor)
    Tsol                [0 0 0 1 0 0 0] 1941;     // K
    Tvap                [0 0 0 1 0 0 0] 3560;     // K
    
    // Kinetic theory parameters
    stickingCoeff       0.18;     // Ti evaporation coefficient
    momentumAccom       0.18;     // Momentum accommodation
    
    //windowWidth         100;
    dtFloor             1e-15;         // Reduced for precision
    relaxationTime      5e-12;        // Faster response for femtosecond dynamics
    // NOTE: The solver expects maxSource in volumetric units [W/m^3].
    // A 71 nm film would limit the surface heat flux to ~70 W/m^2 if this were 1e9.
    // Disable the cap so phase change is not throttled unrealistically.
    maxSource           [1 -1 -3 0 0 0 0]   1e9;;            // Disable volumetric cap; honour physical source term
    minCoefficient      [1 -1 -3 0 0 0 0] 1e7;          // Reduced for gradual cooling
    onlyAboveVapor      false;
    metalFractionCutoff 1e-6;
    // EXTENDED ACTIVATION - through transfer and cooling
    activationTime      ((0 4e-10));  // Active through 400 ps as intended
}

// EXTENDED MASS TRANSFER - through solidification
massTransferCoeffs
{
    tStart  (0);
    tEnd    (4e-10);   // Active through 400 ps
    rateMax 1e11;      // Reduced for later phase stability
}

// LASER TIMING - shorter pulse, longer observation
laserStartTime      0;
laserEndTime    2e-10;

// Advanced interface capturing - TUNED FOR EXTENDED SIMULATION
useAdvancedInterfaceCapturing  true;
advancedInterfaceCapturing
{
    model               kinetic_theory;  // Not arbitrary scaling!
    stickingCoeff       0.18;
    momentumAccom       0.18;
    recoilMax             5e6;      // ✅ REDUCE from 1e7 (5 MPa max)
    clampRecoil           true;
    scaleRecoilMax        false;    // ✅ DISABLE scaling (let physics control it)
    recoilTempOffset      100;      // ✅ INCREASE from 20 (smoother activation)
    phaseChangeTempOffset 100;      // ✅ INCREASE from 20
    recoilRelax           0.3;      // ✅ INCREASE from 0.1 (more damping)
    alphaMin              0.01;
    alphaMax              1;
    maxPhysicalTemperature  50000;

        // Physical limits
    maxRecoilPressure   1e8;    // 100 MPa absolute max
}
logRecoilSuppression true;

// Temperature clamping - EXTENDED RANGE
enableTClamp    false;
minT            200;           // Allow cooling below room temp
maxT            5800;          // Clamp high temperatures to physical limit (~Ti vapor data)

// Two-temperature model properties - OPTIMIZED FOR EXTENDED RUNS
twoTemperatureProperties
{
    
    // Linear electronic heat capacity: Ce = γTe
    Ce
    {
        type        polynomial;
        value       0;
        coeffs
        (
            (0   0)  // Constant term = 0
            (630 1)  // Linear term: Ce = 630 · Te [J/m³/K²]
        );
    }
    
    // Temperature-dependent coupling
    G
    {
        type        table;
        values
        (
            (300     3e17)      // Room temperature
            (1000    1e18)      // 3.3× increase (weak coupling regime)
            (2000    2e18)      // Linear scaling begins
            (3000    3e18)      // Strong coupling regime
            (5000    5e18)      // 16× total
            //(7000    7e18)      // Continues scaling
            //(10000   1e19)      // 33× total
           // (15000   1.5e19)    // 50× total
            //(20000   2e19)      // Upper limit
        );
    }
    
    Cl  [1 -1 -2 -1 0 0 0] 2.5e6;
    De  [0  2 -1  0 0 0 0] 1e-4;

    gasMetalExchangeCoeff
    {
        type        kapitza;    // Use acoustic mismatch model
        Z_metal     2.3e7;      // Ti acoustic impedance [Pa·s/m]
        Z_gas       383;        // Ar acoustic impedance [Pa·s/m]
        rho_metal   4500;       // Ti density [kg/m^3]
        rho_gas     1.7;        // Ar density [kg/m^3]
        maxTemperature 0;      // Optional cap [K] (0 => no cap)
    }
    minGasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 0;
    maxGasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 1e13;
    maxGasMetalHeatFlux    1e11;   // Surface heat flux cap [W/m²]
    
    // ✅ ADJUSTED: Allow higher lattice temperatures now that coupling works
    minTe           200;
    maxTe           8000;       // Align electron cap with material data envelope
    maxTl           5800;       // Match lattice clamp to global maxT

    ambientTemperature 300;
    temperatureDifferenceFloor 10.0;                     // Guard against Te/Tl collapse
    
    // ADAPTIVE MICRO-STEPPING
    electronSubCycles        4;
    minElectronSubCycles     2;
    maxElectronSubCycles     100;    // Ensure ceil(maxDeltaT/maxElectronDeltaT) stays below cap
    maxElectronDeltaT        [0 0 1 0 0 0 0] 1e-15;  // Guard rapid transients

    nInnerCouplingSweeps         3;  // More coupling iterations
    innerCouplingResidualTol     1e-4; // Enable convergence check
    
    klHighTThreshold 1000;
    klExponent       0.5;

    metalFractionFloor      1e-6;
    metalFractionCutoff     1e-6;
    metalAmbientBlendWidth  1e-3;
    CvolGasFloor    1e6;  // J/m^3/K floor for gas cells

    energyTolerance         0.02;    // ✅ CORRECTED: Tightened from 0.05 to 0.02 (2%)
    energyDiagnostics       false;   // ⚠️ DISABLED: Prevents dimensional error in cumulative energy tracking
    temperatureDiagnostics  false;   // ⚠️ DISABLED: Reduce output volume
    energyAudit             false;   // ⚠️ DISABLED: Prevents dimensional error bug
}

// Clean monitoring functions
functions
{
    // Mid-plane visualization (optional)
    midPlaneVTK
    {
        type            surfaces;
        libs            ("libsampling.so");
        writeControl    writeTime;
        writeInterval   1;
        surfaceFormat   vtk;
        fields          (alpha.metal Tl Te T p_rgh U);

        surfaces
        (
            midPlane
            {
                type                cuttingPlane;
                planeType           pointAndNormal;
                pointAndNormalDict
                {
                    point   (25e-6 8.0357e-06 5e-6);  // ✅ CORRECTED: Ti film center
                    normal  (0 1 0);
                }
                interpolate         true;
            }
        );
    }
}

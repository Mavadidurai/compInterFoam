FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     compInterFoam;

startFrom       latestTime;
startTime       0;
stopAt          endTime;
endTime         1e-9;          // EXTENDED: 1 ns total for complete LIFT process

deltaT          1e-15;         // Base time step (1 fs)
adjustTimeStep  yes;           // ENABLE adaptive time stepping
maxCo           0.05;          // Allow reasonable growth while staying stable
maxAlphaCo      0.005;         // Aggressive interface limit
maxDeltaT       1e-12;         // Cap adaptive growth (1 fs)
minDeltaT       1e-17;         // Minimum 0.01 fs for precision

verbose         true;
thermalFluxRelax 0.1;          // Stronger damping of interface heat flux
maxThermalCourant 0.1;         // Tightened for thermal stability

// ADAPTIVE OUTPUT - more frequent during active phase, less during cooling
writeControl    adjustableRunTime;
writeInterval   1e-15;         // Start with 1 ps intervals
purgeWrite      50;            // Keep more time directories for analysis
writeFormat     ascii;
writePrecision  8;
writeCompression off;
timeFormat      general;
timePrecision   8;             // Increased precision for longer runs
fileHandler     uncollated;

runTimeModifiable yes;

// EXTENDED PHASE-CHANGE - longer activation for complete process
phaseChangeCoeffs
{
    model               temperatureWindow;
    hf                  hf  [0 2 -2 0 0 0 0] 3.65e5;
    Tsol                Tsol [0 0 0 1 0 0 0] 1941;
    Tvap                Tvap [0 0 0 1 0 0 0] 3560;
    windowWidth         50;
    dtFloor             1e-15;         // Reduced for precision
    relaxationTime      1e-12;        // Faster response for femtosecond dynamics
    maxSource           1e10;          // Allow sufficient heating-driven mass transfer
    minCoefficient      1e7;          // Reduced for gradual cooling
    onlyAboveVapor      true;
    metalFractionCutoff 1e-6;
    // EXTENDED ACTIVATION - through transfer and cooling
    activationTime      ((0 2e-10));  // Active through 400 ps
}

// EXTENDED MASS TRANSFER - through solidification
massTransferCoeffs
{
    tStart  (0);
    tEnd    (2e-10);   // Active through 400 ps
    rateMax 1e12;      // Reduced for later phase stability
}

// LASER TIMING - shorter pulse, longer observation
laserStartTime      0;
laserEndTime    1e-10;

// Advanced interface capturing - TUNED FOR EXTENDED SIMULATION
useAdvancedInterfaceCapturing  true;
advancedInterfaceCapturing
{
    pressureScale         1;
    recoilMax             1e7;
    clampRecoil           true;
    scaleRecoilMax        true;
    recoilTempOffset      20;
    phaseChangeTempOffset 20;
    recoilRelax           0.1;
    alphaMin              0.05;
    alphaMax              0.95;
    maxPhysicalTemperature 5000;    
}

logRecoilSuppression true;

// Temperature clamping - EXTENDED RANGE
enableTClamp    false;
minT            200;           // Allow cooling below room temp
maxT            15000;          // Clamp high temperatures for stability

// Two-temperature model properties - OPTIMIZED FOR EXTENDED RUNS
twoTemperatureProperties
{
    Ce  [1 -1 -2 -1 0 0 0] 1.5e6;
    Cl  [1 -1 -2 -1 0 0 0] 2.5e6;
    G   [1 -1 -3 -1 0 0 0] 5e17;
    De  [0  2 -1  0 0 0 0] 1e-4;

    gasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 1e10;
    minGasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 0;
    maxGasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 1e13;
    maxGasMetalHeatFlux    1e12;
    minTe 200;             // Allow cooling
    maxTe 15000;
    ambientTemperature 300;

    // ADAPTIVE MICRO-STEPPING
    electronSubCycles        1;
    minElectronSubCycles     1;
    maxElectronSubCycles     20;     // Allow rapid transients
    maxElectronDeltaT        [0 0 1 0 0 0 0] 1e-14;  // Guard rapid transients

    nInnerCouplingSweeps         3;  // More coupling iterations
    innerCouplingResidualTol     1e-4; // Enable convergence check
    
    klHighTThreshold 1000;
    klExponent       0.5;

    metalFractionFloor      1e-6;
    metalFractionCutoff     1e-6;
    metalAmbientBlendWidth  1e-3;

    energyTolerance         0.02;    // Relaxed for long runs
    energyDiagnostics       true;
    temperatureDiagnostics  true;   // Reduce output volume
    energyAudit             true;
}

// Clean monitoring functions
functions
{
  // Adaptive output frequency based on simulation phase
    phaseAdaptiveOutput
    {
        type            coded;
        libs            ("libutilityFunctionObjects.so");
        name            phaseAdaptiveOutput;
        writeControl    timeStep;
        writeInterval   1;

        codeWrite
        #{
            const scalar t = mesh().time().value();
            static scalar activeWriteInterval = -1;
            static scalar nextWriteTime = -1;
            scalar newInterval = 1e-12;  // Default 1 ps

            if (t < 1e-10)       newInterval = 1e-12;  // 1 ps
            else if (t < 3e-10)  newInterval = 2e-12;  // 2 ps
            else if (t < 5e-10)  newInterval = 5e-12;  // 5 ps
            else                 newInterval = 1e-11;  // 10 ps

            Time& runTime = const_cast<Time&>(mesh().time());
            const scalar currentDeltaT = runTime.deltaTValue();

            if
            (
                activeWriteInterval < 0
             || mag(newInterval - activeWriteInterval) > 0.1e-12
            )
            {
                activeWriteInterval = newInterval;

                label completedSteps = 0;
                if (activeWriteInterval > 0)
                {
                    completedSteps = label(t/activeWriteInterval);
                }

                nextWriteTime = (completedSteps + 1)*activeWriteInterval;

                if (nextWriteTime <= t + 0.5*currentDeltaT)
                {
                    nextWriteTime += activeWriteInterval;
                }

                if (Pstream::master()) {
                    Info<< "Adaptive output: Changed write interval to "
                        << activeWriteInterval*1e12 << " ps at t="
                        << t*1e12 << " ps" << endl;
                }
            }

            const scalar writeTolerance = 0.5*currentDeltaT;

            if (nextWriteTime >= 0 && t + writeTolerance >= nextWriteTime) {
                const scalar originalTime = t;
                const label originalIndex = runTime.timeIndex();

                runTime.setTime(nextWriteTime, originalIndex);
                runTime.writeNow();
                runTime.setTime(originalTime, originalIndex);

                nextWriteTime += activeWriteInterval;
                }
        #};
    }

    // Mid-plane visualization (optional)
    midPlaneVTK
    {
        type            surfaces;
        libs            ("libsampling.so");
        writeControl    writeTime;
        writeInterval   1;
        surfaceFormat   vtk;
        fields          (alpha.metal Tl Te T p_rgh U);

        surfaces
        (
            midPlane
            {
                type                cuttingPlane;
                planeType           pointAndNormal;
                pointAndNormalDict
                {
                    point   (25e-6 2.00357e-05 5e-6);
                    normal  (0 1 0);
                }
                interpolate         true;
            }
        );
    }
}

FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      Tl;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;

boundaryField
{
    left     { type symmetryPlane; }
    right    { type symmetryPlane; }
    front    { type symmetryPlane; }
    back     { type symmetryPlane; }

    // ✅ CORRECTED BOUNDARIES:
    // BOTTOM - donorSubstrate (transparent glass/quartz) - heat sink
    donorSubstrate
    {
        type            fixedValue;
        value           uniform 300;  // Transparent substrate heat sink
    }

    // TOP - receiver (deposition target) - minimal thermal interference
    receiver
    {
        type            zeroGradient;
    }
}

// ✅ CORRECTED REASONING:
// - donorSubstrate (bottom): Transparent substrate acts as heat sink
// - receiver (top): Receiver substrate - minimal thermal interference
// - This allows proper temperature buildup in Ti donor film (8.0-8.0714 µm)
// - Laser enters from bottom, heats film, material ejects upward
// ************************************************************************* //

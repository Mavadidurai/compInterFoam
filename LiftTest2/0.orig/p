FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 1e5;     // ambient reference

boundaryField
{
  left          { type symmetryPlane; }
  right         { type symmetryPlane; }
  front         { type symmetryPlane; }
  back          { type symmetryPlane; }
  donorSubstrate { type calculated; value uniform 1e5; }  // ✅ CORRECTED: bottom
  receiver       { type calculated; value uniform 1e5; }  // ✅ CORRECTED: top
}


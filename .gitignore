# OpenFOAM simulation output files
# Time directories (runtime outputs - exclude from version control)
*/[0-9]*/
*/[0-9].[0-9]*/
*/0/
# Note: 0.orig/ is NOT ignored - it contains template initial conditions

# Log files
*.log
log.*
*.out

# Processor directories (parallel decomposition)
processor*/

# Post-processing
postProcessing/

# Mesh files (binary)
*.obj

# Dynamic code
dynamicCode/

# VTK output
*.vtk
*.vtu

# Other temporary files
*~
*.swp
*.swo
.*.swp
nohup.out

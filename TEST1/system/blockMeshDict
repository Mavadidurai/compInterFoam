FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

scale 1e-6; // coordinates in micrometers

// âś… FORWARD TRANSFER (LIFT) GEOMETRY (bottom to top):

// y0 = 0.0000     - Receiver substrate bottom (deposition target)

// y1 = 8.0000     - Receiver substrate top / Air gap bottom

// y2 = 20.0000    - Air gap top / Donor substrate bottom

// y3 = 28.0000    - Donor substrate top (transparent glass/quartz) / Ti film bottom

// y4 = 28.0714    - Ti film top (71.4 nm thick) - laser entry point

vertices
(

    // y0 = 0.0000 (receiver substrate bottom - deposition target)

    (0   0.0000  0)  (50  0.0000  0)  (50  0.0000 10)  (0   0.0000 10)



    // y1 = 8.0000 (receiver substrate top / air gap bottom)
    (0   8.0000  0)  (50  8.0000  0)  (50  8.0000 10)  (0   8.0000 10)

    // y2 = 20.0000 (air gap top / donor substrate bottom)
    (0  20.0000  0)  (50 20.0000  0)  (50 20.0000 10)  (0  20.0000 10)

    // y3 = 28.0000 (donor substrate top / Ti film bottom)
    (0  28.0000  0)  (50 28.0000  0)  (50 28.0000 10)  (0  28.0000 10)

    // y4 = 28.0714 (Ti film top - laser entry from above)
    (0  28.0714  0)  (50 28.0714  0)  (50 28.0714 10)  (0  28.0714 10)

);
blocks

(
    // Resolution: 250 nm in X,Z (captures 3.2Âµm laser spot); 4.76 nm in Ti film Y-direction

    hex ( 0  3  2  1   4  7  6  5)   ( 40 200  40)  simpleGrading (1 1 1)  // Receiver substrate (8 Âµm): 0.2 Âµm/cell in Y

    hex ( 4  7  6  5   8 11 10  9)   ( 40 200  60)  simpleGrading (1 1 1)  // Air gap (12 Âµm): 0.2 Âµm/cell in Y

    hex ( 8 11 10  9  12 15 14 13)   ( 40 200  40)  simpleGrading (1 1 1)  // Transparent donor substrate (8 Âµm): 0.2 Âµm/cell in Y

    hex (12 15 14 13  16 19 18 17)   ( 40 200  15)  simpleGrading (1 1 1)  // Ti film (71.4 nm): 4.76 nm/cell in Y, 3.5 cells/penetration depth

);

edges ();

 

boundary

(

    // Symmetry planes (external boundaries only)

    left          { type symmetryPlane; faces ((0 3 7 4)(4 7 11 8)(8 11 15 12)(12 15 19 16)); }

    right         { type symmetryPlane; faces ((1 5 6 2)(5 9 10 6)(9 13 14 10)(13 17 18 14)); }

    front         { type symmetryPlane; faces ((0 4 5 1)(4 8 9 5)(8 12 13 9)(12 16 17 13)); }

    back          { type symmetryPlane; faces ((3 2 6 7)(7 6 10 11)(11 10 14 15)(15 14 18 19)); }

 

    // âś… FORWARD TRANSFER: Laser enters through donor substrate at TOP, deposits on receiver at BOTTOM

    receiver        { type wall;  faces ((0 3 2 1)); }      // BOTTOM - receiver substrate (deposition target)

    donorSubstrate  { type wall;  faces ((16 19 18 17)); }  // TOP - transparent donor substrate (laser entry)
);

mergePatchPairs();


FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "alpha.*"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-12;
        relTol          0.0;
        maxIter         100;
        minIter         2;

        nAlphaCorr      3;
        nAlphaSubCycles 3;              // Increased to stabilise transport
        cAlpha          2.0;            // Sharper compression to avoid smearing the thin film
        icAlpha         0;
        scAlpha         0;
        compressionLimiter 0.5;         // Caps phic relative to |phi|
        MULESCorr       true;
        nLimiterIter    3;
        alphaApplyPrevCorr true;
        sharpeningScheme standard;
        thinFilmCoeff   0.0;
    }

    p_rgh
    {
        solver          GAMG;
        smoother        DICGaussSeidel;
        tolerance       1e-6; //from 1e-5
        relTol          0.005; //from 0.1
        maxIter         200; // Increased from 100 to handle stiff pressure gradients
        nPreSweeps      0;
        nPostSweeps     2;
        cacheAgglomeration true;
        nCellsInCoarsestLevel 20;
        agglomerator    faceAreaPair;
        mergeLevels     2;
        relaxationFactor 0.7;
    }

    p_rghFinal
    {
        $p_rgh;
        tolerance   1e-6;
        relTol      0;
    }
    
    "U.*"
   {
            solver      smoothSolver;
            smoother    symGaussSeidel;
            nSweeps     2;
            tolerance   1e-06;
            relTol      0.1;
            maxIter     200;
            minIter     1;
    }

    T
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        nSweeps         3;                // Reduced from 6
        tolerance       1e-5;             // Relaxed from 1e-8 to prevent hanging
        relTol          0.1;              // Increased from 0.01 for faster convergence
        maxIter         50;               // Reduced from 1000 to prevent deadlock
        minIter         1;                // Reduced from 3
    }

    TFinal
    {
        $T;
        tolerance       1e-6;             // Relaxed from 1e-9
        relTol          0.01;             // Added relative tolerance
        maxIter         100;              // Reduced from 1000
    }

    Te
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        nSweeps         3;                // Reduced from 6
        tolerance       1e-5;             // Relaxed from 1e-8 to prevent hanging
        relTol          0.1;              // Added relative tolerance
        maxIter         50;               // Reduced from 1000 to prevent deadlock
        minIter         1;                // Reduced from 3
    }

    Tl
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        nSweeps         3;                // Reduced from 6
        tolerance       1e-5;             // Relaxed from 1e-8 to prevent hanging
        relTol          0.1;              // Added relative tolerance
        maxIter         50;               // Reduced from 1000 to prevent deadlock
        minIter         1;                // Reduced from 3
    }
}

PIMPLE
{
    momentumPredictor           true;
    nOuterCorrectors            5;           // Reduced from 10 to prevent excessive iterations
    nCorrectors                 2;           // Reduced from 3
    nNonOrthogonalCorrectors    1;           // Reduced from 2

    residualControl
    {
        "alpha.*" { tolerance 1e-6;  relTol 0.0; }   // Relaxed from 1e-8
        p_rgh     { tolerance 1e-4;  relTol 0.05; }  // Relaxed from 1e-5
        U         { tolerance 1e-4;  relTol 0.1; }   // Relaxed relTol from 0.05
        Te        { tolerance 1e-5;  relTol 0.1;  }  // Relaxed from 1e-8, added relTol
        Tl        { tolerance 1e-5;  relTol 0.1;  }  // Relaxed from 1e-8, added relTol
        T         { tolerance 1e-5;  relTol 0.1;  }  // Relaxed from 1e-7
    }
    
    p_rghRefCell                0;
    p_rghRefValue               101325;
}

relaxationFactors
{
    fields
    {
        p_rgh           0.3;
        "alpha.*"       0.5;
    }
    equations
    {
        U               0.5;
        T               0.5;
        Te              0.5;
        Tl              0.5;
        "alpha.*"       0.5;
        ".*Final"       0.7;
    }
}

// Pressure relaxation control
targetResP  0.5;

compInterFoamCoeffs
{
    // CRITICAL FIX: Remove artificial velocity clamping
    maxVelocity            0;         // DISABLED: was causing uniform 500 m/s field
    maxReasonableVelocity  800;       // Keep for validation warnings only
    // NOTE: Feinaeugle et al. (Appl. Surf. Sci. 418, 2017) report fs-LIFT recoil
    // peaks around 70–80 MPa.  Resolving that across the 71.4 nm film requires
    // |∇p| ≈ 1×10^15 Pa/m, so lift the limiter accordingly.
    maxPressureGradient    1e16;
        
    defaultMetalDensity    4500;        
    defaultAirDensity      1.2;         
    maxInitialResidual     10;

    // Interface clamp settings
    enableAlphaClamp  false;
    minAlpha          0.001;
    maxAlpha          0.999;

    // Clamp p_rgh to a physically defensible range so GAMG cannot run away.
    // Feinaeugle et al. observe Ti recoil plateaus close to 80 MPa, so keep the ceiling
    // above that to avoid throttling the kinetic-theory recoil driver.
    pressureClamp      false;
    maxPressure        5.0e9;
    minPressure       -5e6;

    // Density clamp settings
    densityClamp       false;
    maxDensity         10000;
    minDensity         0.5;

    // RAU clamp settings  
    enableRAUClamp     false;
    minRAU             1e-10;
    maxRAU             1e6;
    minRAUf            1e-14;
    maxRAUf            1e6;

    // Diagonal safety (keep this)
    minUEqnDiag        1e-9;

    // RELAX RESIDUAL TARGETS
    targetResU         0.1;
    targetResP         0.5;
}

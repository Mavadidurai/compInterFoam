FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "alpha.*"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-12;
        relTol          0.0;
        maxIter         100;
        minIter         2;
        nAlphaCorr      5;
        nAlphaSubCycles 5;              // Increased to stabilise transport
        cAlpha          1.0;            // Softer compression to avoid overshoot
        icAlpha         0;
        scAlpha         0;
        compressionLimiter 1.0;         // Caps phic relative to |phi|
        MULESCorr       true;
        nLimiterIter    5;
        alphaApplyPrevCorr true;
        sharpeningScheme standard;
        thinFilmCoeff   0.0;
    }

    p_rgh
    {
        solver          GAMG;
        smoother        DICGaussSeidel;
        tolerance       1e-5;           // Relaxed from 1e-6
        relTol          0.01;           // Relaxed from 0.005
        maxIter         500;            // Increased for extreme gradients
        nPreSweeps      1;              // Added pre-sweeps
        nPostSweeps     3;              // Increased post-sweeps
        cacheAgglomeration true;
        nCellsInCoarsestLevel 10;       // Finer coarsest level
        agglomerator    faceAreaPair;
        mergeLevels     1;              // Less aggressive merging
        relaxationFactor 0.5;           // More conservative relaxation
    }

    p_rghFinal
    {
        $p_rgh;
        tolerance   1e-6;
        relTol      0;
    }
    
    "U.*"
   {
            solver      smoothSolver;
            smoother    symGaussSeidel;
            nSweeps     2;
            tolerance   1e-06;
            relTol      0.1;
            maxIter     200;
            minIter     1;
    }

    T
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        nSweeps         6;
        tolerance       1e-8;
        relTol          0.01;             // Allow 1% relative convergence
        maxIter         1000;             // Increased iteration limit
        minIter         3;                // Ensure minimum work
    }

    TFinal
    {
        $T;
        tolerance       1e-9;
        relTol          0;
        maxIter         1000;
    }

    Te
    {
         solver          smoothSolver;
        smoother        symGaussSeidel;
        nSweeps         6;
        tolerance       1e-8;
        relTol          0;
        maxIter         1000;
        minIter         3;
    }

    Tl
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        nSweeps         6;
        tolerance       1e-8;
        relTol          0;
        maxIter         1000;
        minIter         3;
    }
}

PIMPLE
{
    momentumPredictor           true;
    nOuterCorrectors            30;          // Increased to handle extreme recoil pressures
    nCorrectors                 5;           // Increased pressure correctors
    nNonOrthogonalCorrectors    3;           // More non-orthogonal corrections

    residualControl
    {
        "alpha.*" { tolerance 1e-6;  relTol 0.0; }    // Relaxed for extreme conditions
        p_rgh     { tolerance 1e-4;  relTol 0.05; }   // Relaxed to allow convergence
        U         { tolerance 1e-3;  relTol 0.1; }    // Relaxed
        Te        { tolerance 1e-6;  relTol 0.0;  }   // Slightly relaxed
        Tl        { tolerance 1e-6;  relTol 0.0;  }   // Slightly relaxed
        T         { tolerance 1e-6;  relTol 0.05;  }
    }
    
    p_rghRefCell                0;
    p_rghRefValue               101325;
}

relaxationFactors
{
    fields
    {
        p_rgh           0.5;            // Increased from 0.3 for better stability
        "alpha.*"       0.7;            // Increased from 0.5
    }
    equations
    {
        U               0.7;            // Increased from 0.5
        T               0.7;            // Increased from 0.5
        Te              0.7;            // Increased from 0.5
        Tl              0.7;            // Increased from 0.5
        "alpha.*"       0.7;            // Increased from 0.5
        ".*Final"       0.9;            // Increased from 0.7
    }
}

// Pressure relaxation control
targetResP  0.5;

compInterFoamCoeffs
{
    // CRITICAL FIX: Remove artificial velocity clamping
    maxVelocity            0;         // DISABLED: was causing uniform 500 m/s field
    maxReasonableVelocity  800;       // Keep for validation warnings only
    // NOTE: Feinaeugle et al. (Appl. Surf. Sci. 418, 2017) report fs-LIFT recoil
    // peaks around 70–80 MPa.  Resolving that across the 71.4 nm film requires
    // |∇p| ≈ 1×10^15 Pa/m, so lift the limiter accordingly.
    maxPressureGradient    1e16;
        
    defaultMetalDensity    4500;        
    defaultAirDensity      1.2;         
    maxInitialResidual     10;

    // Interface clamp settings
    enableAlphaClamp  false;
    minAlpha          0.001;
    maxAlpha          0.999;

    // Clamp p_rgh to a physically defensible range so GAMG cannot run away.
    // Femtosecond laser ablation can generate recoil pressures exceeding 20 GPa
    // Increased limit to accommodate ultrafast dynamics
    pressureClamp      true;
    maxPressure        2.5e10;        // 25 GPa - allows physical recoil pressures
    minPressure       -5e6;

    // Density clamp settings
    densityClamp       false;
    maxDensity         10000;
    minDensity         0.5;

    // RAU clamp settings  
    enableRAUClamp     false;
    minRAU             1e-10;
    maxRAU             1e6;
    minRAUf            1e-14;
    maxRAUf            1e6;

    // Diagonal safety (keep this)
    minUEqnDiag        1e-9;

    // RELAX RESIDUAL TARGETS
    targetResU         0.1;
    targetResP         0.5;
}

FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      dynamicMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dynamicFvMesh   dynamicRefineFvMesh;

dynamicRefineFvMeshCoeffs
{
    field            alpha.metal;
    refineInterval   1;
    lowerRefineLevel 0.01;
    upperRefineLevel 0.99;
    unrefineLevel    0.005;
    nBufferLayers    2;
    maxRefinement    1;         // Reduced from 2 to 1 for quick validation

    maxCells         5000000;   // Reduced from 30M to 5M for quick validation
    correctFluxes    (phi alphaPhi10 rhoPhi);
}


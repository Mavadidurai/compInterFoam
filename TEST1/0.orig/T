FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;     // thesis-style ambient start

boundaryField
{
  left      { type symmetryPlane; }
  right     { type symmetryPlane; }
  front     { type symmetryPlane; }
  back      { type symmetryPlane; }

donorSubstrate { type fixedValue; value uniform 300; }  // ✅ CORRECTED: bottom boundary

receiver

{

    type            zeroGradient;  // ✅ CORRECTED: top boundary

}

}


FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      Te;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;

boundaryField
{
    left     { type symmetryPlane; }
    right    { type symmetryPlane; }
    front    { type symmetryPlane; }
    back     { type symmetryPlane; }

    // BOTTOM - substrate (receiver) - strong heat sink
    substrate
    {
        type            mixed;
        refValue        uniform 300;       // Sink temperature
        refGradient     uniform 0;
        valueFraction   uniform 0.9;       // 90% fixed, 10% gradient
        value           uniform 300;
    }
    
    // TOP - donor (transparent glass) - weak coupling
    donor
    {
        type            mixed;
        refValue        uniform 300;
        refGradient     uniform 0;
        valueFraction   uniform 0.1;       // 10% fixed, 90% gradient
        value           uniform 300;
    }

}

// REASONING:
// - Substrate (bottom): Strong heat sink - removes excess energy
// - Donor (top): Glass substrate - minimal thermal interference
// - This allows proper temperature buildup in metal film
// - Prevents over-cooling from both sides



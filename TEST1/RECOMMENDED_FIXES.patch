     minCoefficient      1e6;          // Reduced for gradual cooling
     onlyAboveVapor      false;
     metalFractionCutoff 1e-6;
@@ -112,7 +112,7 @@
     // Knight (Phys. Rev. B 20, 1979) predicts recoil pressures exceeding
     // 0.3 GPa near 6000 K.  The fs deposition pushes Tl well beyond that, so
     // allow the kinetic-theory recoil driver to reach the multi-GPa recoil
     // levels observed in ultrafast LIFT experiments before clamping.
-    recoilMax             5.0e8;
+    recoilMax             2.0e8;      // 200 MPa (2.5× Feinaeugle observed peak of ~80 MPa)
     clampRecoil           false;
     scaleRecoilMax        false;
     recoilRelax           0.7;


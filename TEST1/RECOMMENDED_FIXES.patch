--- system/controlDict.original
+++ system/controlDict.fixed
@@ -66,7 +66,7 @@
                                                    // Will reach ~2200K at t ≈ 0.2ps (end of pulse)

     // Kinetic theory parameters
-    evaporationCoeff       0.03;     // Ti evaporation coefficient
+    evaporationCoeff       0.18;     // Ti evaporation coefficient (standard literature value)
     alphaMin              0.001;
     dtFloor             1e-15;         // Reduced for precision
     relaxationTime      1e-11;        // Faster response for femtosecond dynamics
-    maxSource           [1 -1 -3 0 0 0 0] 1e7;         // Hertz-Knudsen-consistent mass flux to avoid unphysical recoil (Feinaeugle et al., Appl. Surf. Sci. 418, 2017)

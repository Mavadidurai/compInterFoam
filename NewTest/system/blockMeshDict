FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
scale 1e-6; // coordinates in micrometers

// Domain: x:[0,50] µm, z:[0,10] µm, y vertical (up)
// y-planes (two 12 µm gaps): 0.0000, 8.0000, 8.0714, 20.0714, 32.0714
vertices
(
    // y0 = 0.0000 (donor glass bottom)
    (0   0.0000  0)  (50  0.0000  0)  (50  0.0000 10)  (0   0.0000 10)
    // y1 = 8.0000 (top of glass = bottom of Ti)
    (0   8.0000  0)  (50  8.0000  0)  (50  8.0000 10)  (0   8.0000 10)
    // y2 = 8.0714 (top of Ti) 71.4 nm
    (0   8.0714  0)  (50  8.0714  0)  (50  8.0714 10)  (0   8.0714 10)
    // y3 = 20.0714 (top of first air gap)
    (0  20.0714  0)  (50 20.0714  0)  (50 20.0714 10)  (0  20.0714 10)
    // y4 = 32.0714 (top of second air gap)
    (0  32.0714  0)  (50 32.0714  0)  (50 32.0714 10)  (0  32.0714 10)
);


blocks
(
    //                y-low face       y-high face        Nz   Nx   Ny
    hex ( 0  3  2  1   4  7  6  5)   (20 240  80)  simpleGrading (1 1 1)  // Glass
    hex ( 4  7  6  5   8 11 10  9)   (20 240 2)    simpleGrading (1 1 2.0)  // Ti film (20 cells across 71.4 nm)
    hex ( 8 11 10  9  12 15 14 13)   (20 240 120)  simpleGrading (1 1 1)  // Air gap 1 (12 µm)
    hex (12 15 14 13  16 19 18 17)   (20 240 120)  simpleGrading (1 1 1)  // Air gap 2 (12 µm)
);
edges ();

boundary
(
  left          { type symmetryPlane; faces ((0 3 7 4)(4 7 11 8)(8 11 15 12)(12 15 19 16)); }
  right         { type symmetryPlane; faces ((1 5 6 2)(5 9 10 6)(9 13 14 10)(13 17 18 14)); }

  front         { type symmetryPlane; faces ((0 4 5 1)(4 8 9 5)(8 12 13 9)(12 16 17 13)); }
  back          { type symmetryPlane; faces ((3 2 6 7)(7 6 10 11)(11 10 14 15)(15 14 18 19)); }

  substrate     { type wall;  faces ((16 19 18 17)); }     // receiver wall (top of second air gap)
  donor         { type wall;  faces ((0 1 2 3)); }         // donor glass bottom wall
);

mergePatchPairs();

FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     compInterFoam;

// --- EMERGENCY STABILITY MODE ---
startFrom       startTime;
startTime       2e-10;          // 200 ps
stopAt          endTime;
endTime         2.1e-10;        // Very short test: 210 ps
//endTime         3e-10;        // Use this when stable

// --- ULTRA-CONSERVATIVE TIME STEPPING ---
deltaT          5e-15;          // 0.005 ps (1/4 of characteristic time)
maxDeltaT        1e-12;
minDeltaT        1e-15;
adjustTimeStep  yes;
maxCo           0.1;          // Ultra-conservative
maxAlphaCo      0.05;         // Even more conservative

verbose         true;

// --- More frequent writing for debugging ---
writeControl    runTime;
writeInterval   5e-12;          // 0.5 ps intervals
purgeWrite      20;             
writeFormat     ascii;
writePrecision  12;
writeCompression off;           
timeFormat      general;
timePrecision   15;             // Higher precision for small time steps
fileHandler     uncollated;

runTimeModifiable yes;

// --- DRASTICALLY REDUCE RECOIL PRESSURE ---
useAdvancedInterfaceCapturing  true;
advancedInterfaceCapturing
{
    pressureScale        1e-2;          // DRASTICALLY reduced from 1e2
    recoilMax            1e3;           // Much smaller: only 1000 Pa
    clampRecoil          true;
    scaleRecoilMax       true;
    
    recoilTempOffset     [0 0 0 1 0 0 0] 1000;  // Higher threshold
    phaseChangeTempOffset [0 0 0 1 0 0 0] 500;   // Higher threshold
    relaxFactor          0.01;          // Maximum relaxation
    alphaMin             0.1;           // Tighter bounds
    alphaMax             0.9;
}

// --- AGGRESSIVE TEMPERATURE CLAMPING ---
enableTClamp    true;
minT            250;            // Higher minimum
maxT            4000;           // MUCH lower maximum initially

// --- WEAKEN TWO-TEMPERATURE COUPLING ---
twoTemperatureProperties
{
    Ce   [1 -1 -2 -1 0 0 0] 2.5e6;
    Cl   [1 -1 -2 -1 0 0 0] 2.536e6;
    G    [1 -1 -3 -1 0 0 0] 1.0e12;    // REDUCED by 300x!!! Critical fix
    energyTol 0.1;              // Very relaxed tolerance
    minTe 250;
    maxTe 4000;                 // Match maxT
    minTl 250;                  // Add lattice bounds
    maxTl 4000;
}

libs ("libutilityFunctionObjects.so");

// --- MINIMAL DIAGNOSTICS ONLY ---
functions
{
    // Critical monitoring only
    minmax_critical
    {
        type            fieldMinMax;
        libs            ("libfieldFunctionObjects.so");
        fields          (T Te Tl alpha.metal p_rgh);
        writeControl    timeStep;
        writeInterval   10;
        log             true;       // Print to console
    }
    
    // Energy conservation monitoring
    energy_monitor
    {
        type            coded;
        libs            ("libutilityFunctionObjects.so");
        name            energyCheck;
        writeControl    timeStep;
        writeInterval   50;
        
        codeWrite
        #{
            Info<< "Energy diagnostics at time " << mesh().time().value() << endl;
            
            const volScalarField& T = mesh().lookupObject<volScalarField>("T");
            const volScalarField& alpha = mesh().lookupObject<volScalarField>("alpha.metal");
            
            scalar maxT = gMax(T);
            scalar minT = gMin(T);
            scalar maxAlpha = gMax(alpha);
            
            Info<< "    Max T: " << maxT << " K" << endl;
            Info<< "    Min T: " << minT << " K" << endl;
            Info<< "    Max alpha: " << maxAlpha << endl;
            
            if (maxT > 5000 || minT < 200 || maxAlpha > 0.95)
            {
                WarningIn("energyCheck") << "Critical values detected!" << endl;
            }
        #};
    }
}

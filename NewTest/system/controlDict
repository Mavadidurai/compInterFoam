FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     compInterFoam;

startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         1e-7;

deltaT          5e-16;
adjustTimeStep  yes;
maxCo           0.07;
maxAlphaCo      0.07;
maxDeltaT       2e-12;           // allow growth after pulse
// optional runtime output verbosity
verbose         true;

writeControl    runTime;           // consistent spacing despite variable Δt
writeInterval   1e-9;             // write every 0.2 ns (keeps disk sane)
purgeWrite      200;            // retain a broader history
writeFormat     ascii;
writePrecision  10;
writeCompression on;
timeFormat      general;
timePrecision   12;
fileHandler     collated;

runTimeModifiable yes;

dynamicFvMesh   dynamicRefineFvMesh;

dynamicRefineFvMeshCoeffs
{
    field            alpha.metal;
    refineInterval   1;
    lowerRefineLevel 0.05;
    upperRefineLevel 0.98;
    unrefineLevel    0.001;
    nBufferLayers    1;
    maxRefinement    3;
    maxCells         4000000;
    correctFluxes    (phi none);
}

// solver switches (kept as in your file)
useAdvancedInterfaceCapturing  true;
advancedInterfaceCapturing
{
    // thresholds (must match your transportProperties metal)
    meltingTemperature   meltingTemperature [0 0 0 1 0 0 0] 1941;
    vaporTemperature     vaporTemperature [0 0 0 1 0 0 0] 3560;

    // strength & stability
    pressureScale        1.0;      // nondim scale used in your model
    recoilMax            5e8;      // Pa cap moderated for stability
    clampRecoil          false;     // disable to remove cap
    scaleRecoilMax       true;     // scale cap with phase change
    recoilUpdateInterval 1;        // evaluate every step
    recoilTempOffset     0;      // K above melting point for activation
    alphaMin             0.05;
    alphaMax             0.98;
    phaseChangeTempOffset  10;
}

// adaptive relaxation used in pEqn.H
relaxP            0.2;
targetResP        0.05;

// (keep your existing maxCo/maxAlphaCo)

enableTClamp                   true;
minT                           250;
maxT                           12000;

densityClamp                   true;
minDensity                     0.5;
maxDensity                     10000;

twoTemperatureProperties
{
    Ce  Ce [1 -1 -2 -1 0 0 0] 2.5e6;
    Cl  Cl [1 -1 -2 -1 0 0 0] 2.536e6;
    G   G  [1 -1 -3 -1 0 0 0] 3.0e16;
    energyTol 0.1; // relative energy change tolerance
}

functions
{
    // keep probes (tiny files), great for spotting jet arrival
    probesTTM_fs
    {
        type probes; libs ("libsampling.so");
        fields (Te Tl T p_rgh U alpha.metal);
        probeLocations ((2.5e-05 7.95e-06 5e-06) (2.5e-05 8.02e-06 5e-06) (2.5e-05 1.20e-05 5e-06));
        writeControl runTime; writeInterval 5e-14;
        timeStart 0; timeEnd 1e-11;
    }
    probesTTM
    {
        type probes; libs ("libsampling.so");
        fields (Te Tl T p_rgh U alpha.metal);
        probeLocations ((2.5e-05 7.95e-06 5e-06) (2.5e-05 8.02e-06 5e-06) (2.5e-05 1.20e-05 5e-06));
        writeControl runTime; writeInterval 1e-11;
        timeStart 1e-11; // after fs window
    }

    // light diagnostics each 10 ns
    CourantNo        { type CourantNo; libs ("libutilityFunctionObjects.so"); writeControl runTime; writeInterval 1e-8; }
    fieldMinMax_T    { type fieldMinMax; libs ("libfieldFunctionObjects.so"); writeControl runTime; writeInterval 1e-8; fields (T); }
    fieldMinMax_alpha{ type fieldMinMax; libs ("libfieldFunctionObjects.so"); writeControl runTime; writeInterval 1e-8; fields (alpha.metal); }

    // write key fields more often than main folders, but still manageable
    fieldWrite
    {
        type writeObjects; libs ("libutilityFunctionObjects.so");
        objects (Q_laser U T alpha.metal p_rgh recoilPressure);
        writeControl runTime; writeInterval 1e-10;   // every 0.1 ns for physics fields
    }
    energyBudget_Q
    {
        type            volFieldValue;
        libs            ("libfieldFunctionObjects.so");
        regionType      all;
        operation       sum;
        fields          (Q_laser);
        writeControl    timeStep;
        writeInterval   1;
        log             true;          // <-- v2406 likes explicit booleans
        writeFields     false;         // don't dump the field, just the sum
    }

    energyBudget_Q
    {
        type            volFieldValue;
        libs            ("libfieldFunctionObjects.so");
        regionType      all;
        operation       sum;
        fields          (Q_laser);
        writeControl    timeStep;
        writeInterval   1;
        log             true;          // <-- v2406 likes explicit booleans
        writeFields     false;         // don't dump the field, just the sum
    }

}


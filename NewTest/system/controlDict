FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     compInterFoam;

// --- Start directly in the ejection phase (skip fs/ps windows)
startFrom       startTime;
startTime       2e-10;          // 200 ps
stopAt          endTime;
endTime         1e-8;           // 10 ns (adjust as needed)

// --- Time stepping for ns dynamics
deltaT          5e-13;          // 0.5 ps initial step
maxDeltaT       5e-11;          // 50 ps cap
adjustTimeStep  yes;
maxCo           0.15;           // relaxed vs fs phase
maxAlphaCo      0.10;

verbose         true;

// --- Writing
writeControl    runTime;
writeInterval   5e-12;          // 5 ps
purgeWrite      200;
writeFormat     ascii;
writePrecision  10;
writeCompression on;
timeFormat      general;
timePrecision   12;
fileHandler     collated;

runTimeModifiable yes;

// --- Interface/recoil settings (same physics, evaluated every step)
useAdvancedInterfaceCapturing  false;
advancedInterfaceCapturing
{
    pressureScale        1e7;
    recoilMax            2e8;       // cap; raise later if needed
    clampRecoil          true;
    scaleRecoilMax       false;
    recoilUpdateInterval 1;
    recoilTempOffset     [0 0 0 1 0 0 0] 600;    // activate at Tvap (set >0 to pre-activate)
    relaxFactor          0.1;
    alphaMin             0.01;
    alphaMax             0.99;
}

// --- Temperature clamps (TTM still active)
enableTClamp    false;
minT            250;
maxT            20000;

// --- Two-temperature model bounds/diagnostics
twoTemperatureProperties
{
    Ce   [1 -1 -2 -1 0 0 0] 2.5e6;
    Cl   [1 -1 -2 -1 0 0 0] 2.536e6;
    G    [1 -1 -3 -1 0 0 0] 3.0e16;
    energyTol 0.005;
    minTe 300;
    maxTe 20000;
}

// ----------------- Diagnostics for ejection phase only ----------------- //
functions
{
  // Write a few key fields at moderate cadence
  fieldWrite
  {
      type writeObjects; libs ("libutilityFunctionObjects.so");
      objects (T Te Tl p_rgh U alpha.metal recoilPressure);
      writeControl runTime; writeInterval 5e-12;   // 5 ps
  }

  // Probes/surfaces in ns window only
  probes_ns
  {
      type            probes;
      libs            ("libsampling.so");
      fields          (T p_rgh U alpha.metal recoilPressure Te Tl);
      probeLocations  (
          (2.5e-05 8.02e-06 5e-06)   // in the film
          (2.5e-05 1.20e-05 5e-06)   // ~3.93 µm above film
      );
      writeControl    runTime;
      writeInterval   5e-12;         // 5 ps
      timeStart       2e-10;
      timeEnd         1e-8;
  }

  minmax_ns
  {
      type            fieldMinMax;
      libs            ("libfieldFunctionObjects.so");
      fields          (T recoilPressure alpha.metal);
      writeControl    runTime;
      writeInterval   5e-12;
      timeStart       2e-10;
      timeEnd         1e-8;
  }

  filmTop_ns
  {
      type            surfaces;
      libs            ("libsampling.so");
      interpolationScheme cellPointFace;
      surfaceFormat   raw;
      fields          (alpha.metal T p_rgh U recoilPressure Te Tl);
      writeControl    runTime;
      writeInterval   5e-12;
      timeStart       2e-10;
      timeEnd         1e-8;
      surfaces
      (
          filmTop
          {
              type        plane;
              planeType   pointAndNormal;
              pointAndNormalDict
              {
                  point   (0 8.0714e-06 0);
                  normal  (0 1 0);
              }
          }
      );
  }

  interfaceIso
  {
      type            surfaces;
      libs            ("libsampling.so");
      writeControl    runTime;
      writeInterval   5e-12;
      interpolationScheme cellPointFace;
      surfaceFormat   raw;
      fields          (alpha.metal T Te Tl p_rgh U recoilPressure);

      surfaces
      (
          interface
          {
              type        isoSurface;
              isoField    alpha.metal;
              isoValue    0.5;
              interpolate true;
              regularise  true;
          }
      );
  }

  U_max_all
  {
      type fieldMinMax; libs ("libfieldFunctionObjects.so");
      fields (U); writeControl timeStep; writeInterval 1;
  }

  U_on_interface
  {
      type surfaces; libs ("libsampling.so");
      surfaceFormat raw; interpolationScheme cellPointFace;
      fields (U); writeControl timeStep; writeInterval 1;
      surfaces
      (
        alphaIso
        {
          type isoSurface; isoField alpha.metal; isoValue 0.5;
          interpolate true; regularise true;
        }
      );
  }

  impactForces
  {
      type         forces;
      libs         ("libforces.so");
      patches      (substrate);
      rho          rho;
      CofR         (0 0 0);
      writeControl runTime;
      writeInterval 5e-12;
  }
}


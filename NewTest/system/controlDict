FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     compInterFoam;

// --- HEATING STAGE SETUP ---
startFrom       startTime;
startTime       0;              // Begin at start of heating pulse
stopAt          endTime;
endTime         3e-10;          // Cover full heating pulse (300 ps)

// --- ULTRA-CONSERVATIVE TIME STEPPING ---
// 0.2 * min(Ce/G, Cl/G) = 6e-13 s -> keep time steps safely below this
deltaT          6e-13;          // 0.005 ps (1/4 of characteristic time)
maxDeltaT        1e-12;
adjustTimeStep  yes;
maxCo           0.1;          // Ultra-conservative
maxAlphaCo      0.05;         // Even more conservative

verbose         true;

// --- More frequent writing for debugging ---
writeControl    runTime;
writeInterval   5e-12;          // 0.5 ps intervals
purgeWrite      20;             
writeFormat     ascii;
writePrecision  12;
writeCompression off;           
timeFormat      general;
timePrecision   15;             // Higher precision for small time steps
fileHandler     uncollated;

runTimeModifiable yes;

// --- ADVANCED INTERFACE CAPTURING ---
useAdvancedInterfaceCapturing  true;
advancedInterfaceCapturing
{
    pressureScale        2e4;           // Recommended scaling
    recoilMax            5e6;           // Allow physical recoil build-up
    clampRecoil          true;
    scaleRecoilMax       false;

    recoilTempOffset     [0 0 0 1 0 0 0] 0;
    phaseChangeTempOffset [0 0 0 1 0 0 0] 0;
    relaxFactor          0.2;
    alphaMin             0.001;
    alphaMax             0.999;
}

// --- TEMPERATURE CLAMPING ---
enableTClamp    true;
minT            300;
maxT            5000;

// --- TWO-TEMPERATURE COUPLING ---
twoTemperatureProperties
{
    Ce   [1 -1 -2 -1 0 0 0] 1.5e6;
    Cl   [1 -1 -2 -1 0 0 0] 2.3e6;
    G    [1 -1 -3 -1 0 0 0] 5e17;
    energyTol 0.01;
    energyTolerance 0.01;
    minTe 300;
    maxTe 6000;
    minTl 300;
    maxTl 6000;
}
libs ("libutilityFunctionObjects.so");

// --- MINIMAL DIAGNOSTICS ONLY ---
functions
{
    // Critical monitoring only
    minmax_critical
    {
        type            fieldMinMax;
        libs            ("libfieldFunctionObjects.so");
        fields          (T Te Tl alpha.metal p_rgh);
        writeControl    timeStep;
        writeInterval   10;
        log             true;       // Print to console
    }
    
    // Energy conservation monitoring
    energy_monitor
    {
        type            coded;
        libs            ("libutilityFunctionObjects.so");
        name            energyCheck;
        writeControl    timeStep;
        writeInterval   50;
        
        codeWrite
        #{
            Info<< "Energy diagnostics at time " << mesh().time().value() << endl;
            
            const volScalarField& T = mesh().lookupObject<volScalarField>("T");
            const volScalarField& alpha = mesh().lookupObject<volScalarField>("alpha.metal");
            
            scalar maxT = gMax(T);
            scalar minT = gMin(T);
            scalar maxAlpha = gMax(alpha);
            
            Info<< "    Max T: " << maxT << " K" << endl;
            Info<< "    Min T: " << minT << " K" << endl;
            Info<< "    Max alpha: " << maxAlpha << endl;
            
            if (maxT > 5000 || minT < 200 || maxAlpha > 0.95)
            {
                WarningIn("energyCheck") << "Critical values detected!" << endl;
            }
        #};
    }
}

FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     compInterFoam;

// --- Start directly in the ejection phase (skip fs/ps windows)
startFrom       startTime;
startTime       2e-10;          // 200 ps
stopAt          endTime;
endTime         3e-10;          // Start with shorter run: 300 ps
//endTime         1e-8;         // 10 ns (use this later when stable)

// --- Time stepping for ns dynamics - VERY CONSERVATIVE
deltaT          1e-14;          // 0.01 ps initial step (much smaller)
maxDeltaT       1e-13;          // 0.1 ps cap (much smaller)
adjustTimeStep  yes;
maxCo           0.005;          // Very conservative - consistent with fvSolution
maxAlphaCo      0.001;          // Ultra-conservative for recoil pressure

verbose         true;

// --- Writing - More frequent for debugging
writeControl    runTime;
writeInterval   5e-12;          // 1 ps for debugging
purgeWrite      50;             // Keep fewer files initially
writeFormat     ascii;
writePrecision  10;
writeCompression on;           // Disable for debugging
timeFormat      general;
timePrecision   12;
fileHandler     uncollated;     // Simpler for debugging

runTimeModifiable yes;

// --- Interface/recoil settings - DISABLED initially for stability
useAdvancedInterfaceCapturing  true;
advancedInterfaceCapturing
{
    pressureScale        1e6;           // Reduced from 1e7
    recoilMax            1e7;           // Much smaller cap initially
    clampRecoil          true;
    scaleRecoilMax       true;          // Enable scaling
    recoilUpdateInterval 5;             // Less frequent updates
    recoilTempOffset     [0 0 0 1 0 0 0] 1000;  // Higher threshold
    relaxFactor          0.05;          // More relaxation
    alphaMin             0.05;          // Wider bounds
    alphaMax             0.95;
}

// --- Temperature clamps - ENABLE for stability
enableTClamp    true;           // Enable clamping
minT            200;            // Conservative minimum
maxT            8000;           // Lower maximum initially

// --- Two-temperature model bounds/diagnostics - More conservative
twoTemperatureProperties
{
    Ce   [1 -1 -2 -1 0 0 0] 2.5e6;
    Cl   [1 -1 -2 -1 0 0 0] 2.536e6;
    G    [1 -1 -3 -1 0 0 0] 3.0e16;
    energyTol 0.01;             // Relaxed tolerance
    minTe 250;                  // Conservative bounds
    maxTe 8000;                 // Conservative bounds
}

// --- Additional stability controls
libs ("libutilityFunctionObjects.so");

// ----------------- Minimal diagnostics for debugging ----------------- //
functions
{
    // Minimal field writing
    fieldWrite
    {
        type writeObjects; 
        libs ("libutilityFunctionObjects.so");
        objects (T alpha.metal p_rgh U);  // Only essential fields initially
        writeControl runTime; 
        writeInterval 5e-12;   // 1 ps
    }

    // Field bounds checking - Critical for debugging
    minmax_debug
    {
        type            fieldMinMax;
        libs            ("libfieldFunctionObjects.so");
        fields          (T alpha.metal p_rgh U rho);
        writeControl    timeStep;
        writeInterval   1;              // Every time step
    }

    // Courant number monitoring
    CourantNo
    {
        type            CourantNo;
        libs            ("libutilityFunctionObjects.so");
        writeControl    timeStep;
        writeInterval   1;
    }

    // Only enable these after basic stability is achieved
    /*
    probes_ns
    {
        type            probes;
        libs            ("libsampling.so");
        fields          (T p_rgh U alpha.metal);
        probeLocations  (
            (2.5e-05 8.02e-06 5e-06)   // in the film
        );
        writeControl    runTime;
        writeInterval   1e-12;
        timeStart       2e-10;
        timeEnd         3e-10;
    }
    */
}

// Only numbers adjusted; no factors/models changed.
// Update the BOX LIMITS below to match your mesh (in meters).
// Coordinate convention: X,Z lateral, Y vertical (gravity in -Y).

FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      setFieldsDict;
}
defaultFieldValues
(
  volScalarFieldValue alpha.metal 0
  volScalarFieldValue alpha.air   1
  volScalarFieldValue Tl          300
  volScalarFieldValue Te          300
  volScalarFieldValue T           300
);

regions
(
    boxToCell
    {
        // film slab: x: [0, 50 µm], y: [8.0000, 8.0714 µm], z: [0, 10 µm]
        box (0        8.0e-06  0)
            (5.0e-05  8.0714e-06  1.0e-05);

        fieldValues
        (
            volScalarFieldValue alpha.metal 1
            volScalarFieldValue alpha.air   0
        );
    }
        // Initialize the film as molten (above Tliq=1941 K, below Tvap=3560 K)
    boxToCell
    {
        // use the same film slab box
        box (0        8.0e-06  0)
           (5.0e-05  8.0714e-06  1.0e-05);

        fieldValues
        (
           volScalarFieldValue Tl 300  // Return to ambient; laser will heat from this baseline
           volScalarFieldValue Te 300  // Keep electronic temperature at ambient preheat level
            // optional but tidy: initialise scalar T too, even though TTM will overwrite it
           volScalarFieldValue T 300   // Maintain consistency with ambient solid/liquid temperature
        );
    }
);

FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
solvers
{
    "alpha.*"
    {
        solver          smoothSolver;        // CHANGE: was PBiCGStab
        smoother        symGaussSeidel;      // CHANGE: was DILU preconditioner
        tolerance       1e-8;                // CHANGE: was 1e-10 (too tight)
        relTol          0;            
        maxIter         50;                  // ADD: limit iterations
        
        nAlphaCorr      1;                   // REDUCE: was 2
        nAlphaSubCycles 2;                   // REDUCE: was 4
        cAlpha          0.5;                 // REDUCE: was 1 (less aggressive)
        icAlpha         0;              
        scAlpha         0;
        MULESCorr       true;
        nLimiterIter    2;                   // REDUCE: was 3
        alphaApplyPrevCorr false;
        sharpeningScheme standard;
        thinFilmCoeff   0.0;
        alphaSourceFloor 1e-3;
    }

    
    p_rgh
    {
        solver          GAMG;
        smoother        DICGaussSeidel;
        tolerance       1e-8;           // Good enough for millisecond scale
        relTol          0.0;           
        maxIter         100;   
        nPreSweeps      0;
        nPostSweeps     2;         
        cacheAgglomeration true;
        nCellsInCoarsestLevel 10;
        agglomerator    faceAreaPair;
        mergeLevels     2;
    }
    
    p_rghFinal { $p_rgh; relTol 0; }
    
  "(U|T|Te|Tl).*"
  {
    solver  PBiCGStab;
    preconditioner DILU;
    tolerance 1e-9;
    relTol   0.01;
  }
}

PIMPLE
{
    momentumPredictor           false;       // CHANGE: was true (disable for stability)
    nOuterCorrectors            2;           // REDUCE: was 4
    nCorrectors                 1;           // REDUCE: was 2
    nNonOrthogonalCorrectors    0;           // REDUCE: was 1
    
    residualControl
    {
        "alpha.*" { tolerance 1e-6;  relTol 0; }  // RELAX: was 1e-8
        p_rgh     { tolerance 1e-5;  relTol 0; }  // RELAX: was 1e-6
        U         { tolerance 1e-6;  relTol 0; }  // RELAX: was 1e-7
    }
    
    p_rghRefCell                0;
    p_rghRefValue               100000;
}

relaxationFactors
{
    fields
    {
        p_rgh           0.05;                // REDUCE: was 0.1
        "alpha.*"       0.3;                 // REDUCE: was 0.5
    }
    equations
    {
        U               0.2;                 // REDUCE: was 0.3
        UFinal          0.7;                 // REDUCE: was 1.0
        T               0.3;                 // REDUCE: was 0.5
        Te              0.3;                 // REDUCE: was 0.5
        Tl              0.3;                 // REDUCE: was 0.5
        "alpha.*"       0.5;                 // REDUCE: was 0.8
        ".*Final"       0.8;                 // REDUCE: was 1.0
    }
}
// Adaptive pressure relaxation controls read by pEqn.H
relaxP      0.05;   // under-relaxation factor (edit here)
targetResP  0.1;   // residual target for updating relaxP
compInterFoamCoeffs
{
    maxReasonableVelocity  1e5;     // UEqn.H
    maxVelocity            5000;    // UEqn.H velocity limiter
    defaultMetalDensity    4500;    // UEqn.H (fallback if rho1 invalid)
    defaultAirDensity      1.2;     // UEqn.H (fallback if rho2 invalid)
    // Keep α bounded but not over-restricted
    enableAlphaClamp  true;
    minAlpha          0.001;                // CHANGE: was 0.0
    maxAlpha          0.999;                // CHANGE: was 1.0
    // Pressure bounds (fall back to controlDict if absent)
    pressureClamp      true;                // CHANGE: was false
    maxPressure        1e6;                 // REDUCE: was 1e8
    minPressure        -1e6;      // keep a modest floor

    // Density bounds (controlDict entries are deprecated)

    densityClamp       false;
    maxDensity         10000;
    minDensity         0.5;

    // Momentum matrix safety (fall back to controlDict if absent)
    enableRAUClamp     false;
    minRAU             1e-10;
    maxRAU             1e6;
    minRAUf            1e-14;
    maxRAUf            1e6;

    // Optional residual targeting used in your code
    targetResU         0.05;
}


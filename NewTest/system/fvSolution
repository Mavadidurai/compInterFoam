FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
solvers
{
    "alpha.*"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-8;           // Relaxed tolerance
        relTol          0.0;            
        maxIter         100;             
        
        nAlphaCorr      2;              
        nAlphaSubCycles 2;              
        cAlpha          1;            // Conservative interface compression
        icAlpha         0;              
        scAlpha         0;
        MULESCorr       true;
        nLimiterIter    3;
        alphaApplyPrevCorr false;
        sharpeningScheme standard;
        thinFilmCoeff   0.0;
        alphaSourceFloor 1e-3; // Minimum alpha value for source terms

    }
    
    p_rgh
    {
        solver          GAMG;
        smoother        DICGaussSeidel;
        tolerance       1e-8;           // Good enough for millisecond scale
        relTol          0.0;           
        maxIter         100;   
        nPreSweeps      0;
        nPostSweeps     2;         
        cacheAgglomeration true;
        nCellsInCoarsestLevel 10;
        agglomerator    faceAreaPair;
        mergeLevels     2;
    }
    
    p_rghFinal { $p_rgh; relTol 0; }
    
  "(U|T|Te|Tl).*"
  {
    solver  PBiCGStab;
    preconditioner DILU;
    tolerance 1e-9;
    relTol   0.01;
  }
}

PIMPLE
{
    momentumPredictor           true;   
    nOuterCorrectors            2;      // Reduced - don't need so many
    nCorrectors                 2;      
    nNonOrthogonalCorrectors    1;      
    
    outerCorrectorResidualControl
    {
        p_rgh   { tolerance 1e-5; relTol 0; }
        U       { tolerance 1e-5; relTol 0; }
    }
    
    p_rghRefCell                0;
    p_rghRefValue               100000;
}

relaxationFactors
{
    fields
    {
        p_rgh           0.2;            
        "alpha.*"       0.5;            
    }
    equations
    {
        U               0.5;            // More aggressive - stable at this scale
        UFinal          1.0;            
        T               0.5;            
        Te              0.5;            // Still conservative for electron temp
        Tl              0.5;            
        ".*Final"       1.0;            
    }
}
relaxP      0.3;   // pEqn.H reads from mesh.solutionDict()
targetResP  0.1;   // pEqn.H reads from mesh.solutionDict()
compInterFoamCoeffs
{
    maxReasonableVelocity  1e5;     // UEqn.H
    maxVelocity            10000;    // UEqn.H velocity limiter
    defaultMetalDensity    4500;    // UEqn.H (fallback if rho1 invalid)
    defaultAirDensity      1.2;     // UEqn.H (fallback if rho2 invalid)
    // Keep α bounded but not over-restricted
    enableAlphaClamp  true;
    minAlpha          0.0;
    maxAlpha          1.0;
    // Pressure bounds (fall back to controlDict if absent)
    pressureClamp      true;
    maxPressure        5e8;   // 100 MPa is plenty and cuts clamp spread
    minPressure        1e5;   // keep a modest floor

    // Density bounds (fall back to controlDict if absent)
    densityClamp       true;
    maxDensity         10000;
    minDensity         0.5;

    // Momentum matrix safety (fall back to controlDict if absent)
    enableRAUClamp     true;
    minRAU             1e-14;
    maxRAU             1e6;
    minRAUf            1e-14;
    maxRAUf            1e6;

    // Optional residual targeting used in your code
    targetResU         0.05;
}


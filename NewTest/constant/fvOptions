FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      fvOptions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

substrateFixedVelocity
{
    type            vectorFixedValueConstraint;
    active          yes;

    selectionMode   cellZone;
    cellZone        substrate;

    fieldValues
    {
        U   (0 0 0);
    }
}
substrateFixedTemperature
{
    type            scalarFixedValueConstraint;
    active          no;
    selectionMode   cellZone;
    cellZone        substrate;

    fieldValues
    {
        //T   500;
    }
}

dynamicFvMesh   dynamicRefineFvMesh;

dynamicRefineFvMeshCoeffs
{
    field            alpha.metal;
    refineInterval   1;
    lowerRefineLevel 0.05;
    upperRefineLevel 0.98;
    unrefineLevel    0.001;
    nBufferLayers    2;
    maxRefinement    4;
    maxCells         4000000;
    correctFluxes    (phi (alpha.metal));  // keep this!
}


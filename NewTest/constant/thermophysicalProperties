FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phases (metal air);
sigma           sigma [ 1 0 -2 0 0 0 0 ] 1.64;         // N/m - Metal-air surface tension
metal
{
    transportModel  Newtonian;
    nu              nu [ 0 2 -1 0 0 0 0 ] 5e-7;         // Kinematic viscosity
    rho             rho [ 1 -3 0 0 0 0 0 ] 4515;         // Titanium density

    thermoType
    {
        type            heRhoThermo;
        mixture         pureMixture;
        transport       const;
        thermo          hConst;
        equationOfState rhoConst;       // Constant density for basic test
        specie          specie;
        energy          sensibleEnthalpy;
    }

    mixture
    {
        specie
        {
            molWeight       47.867;         // kg/kmol - Titanium molecular weight
        }

        thermodynamics
        {
            Cp              560;            // J/kg·K - Heat capacity
            Hf              0.0;            // J/kg - Heat of formation
            Tref            300;            // K - Reference temperature
            Href            0;              // J/kg - Reference enthalpy
        }

        transport
        {
            mu              2.25e-3;        // Pa·s - Dynamic viscosity
            Pr              0.03;           // Prandtl number (liquid metals)
        }

        equationOfState
        {
            rho             4515;           // kg/m³ - Titanium density
        }
    }

    // LIFT-specific properties
    Tsol                1941.0;             // K - Solidus temperature
    Tliq                1941.0;             // K - Liquidus temperature
    Tvap                3560.0;             // K - Vaporisation temperature
    hf                  3.65e5;             // J/kg - Latent heat of fusion
    kappa               17.2;               // W/m·K - Thermal conductivity
}

air
{
    transportModel  Newtonian;
    nu              nu [ 0 2 -1 0 0 0 0 ] 1.48e-5;       // Air kinematic viscosity
    rho             rho [ 1 -3 0 0 0 0 0 ] 1.2;           // Air density

    thermoType
    {
        type            heRhoThermo;
        mixture         pureMixture;
        transport       const;           // Simple constant transport
        thermo          hConst;          // Constant thermodynamics
        equationOfState rhoConst;        // Constant density
        specie          specie;
        energy          sensibleEnthalpy;
    }

    mixture
    {
        specie
        {
            molWeight   28.97;              // kg/kmol - Air molecular weight
        }

        thermodynamics
        {
            Cp          1000;               // J/kg·K - Air specific heat
            Hf          0.0;                // J/kg - Heat of formation
            Tref        300;                // K - Reference temperature
            Href        0;                  // J/kg - Reference enthalpy
        }

        transport
        {
            mu          1.8e-5;             // Pa·s - Air dynamic viscosity
            Pr          0.7;                // Prandtl number for air
        }

        equationOfState
        {
            rho         1.2;                // kg/m³ - Constant air density
        }
    }
}

// thermophysical properties for both phases now live in this file


FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phases (metal air);
sigma           sigma [ 1 0 -2 0 0 0 0 ] 1.64;         // N/m - Metal-air surface tension
metal
{
    transportModel  Newtonian;
    nu              nu [ 0 2 -1 0 0 0 0 ] 5e-7;     // Kinematic viscosity
    rho             rho [ 1 -3 0 0 0 0 0 ] 4515;     // Titanium density
}

air
{
    transportModel  Newtonian;
    nu              nu [ 0 2 -1 0 0 0 0 ] 1.48e-5;   // Air kinematic viscosity
    rho             rho [ 1 -3 0 0 0 0 0 ] 1.2;       // Air density
}

/*  
   NOTE:
   This top-level file is intentionally left minimal.
   Phase definitions are in:
     - thermophysicalProperties.metal
     - thermophysicalProperties.air

   Do NOT duplicate sigma, latentHeat, etc. here.
   Those live in constant/transportProperties.
*/


FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phases (metal air);

metal
{
    transportModel  Newtonian;
    nu              nu [ 0 2 -1 0 0 0 0 ] 5e-7;
    rho             rho [ 1 -3 0 0 0 0 0 ] 4515;
}

air
{
    transportModel  Newtonian;
    nu              nu [ 0 2 -1 0 0 0 0 ] 1.48e-5;
    rho             rho [ 1 -3 0 0 0 0 0 ] 1.2;
}

meltingTemperature       [0 0 0 1 0 0 0] 1941.0;
vaporTemperature         [0 0 0 1 0 0 0] 3560.0;
latentHeat               [0 2 -2 0 0 0 0] 3.65e5;

//sigma           sigma [ 1 0 -2 0 0 0 0 ] 1.64;

cAlpha          cAlpha [0 0 0 0 0 0 0] 1;
icAlpha         icAlpha [0 0 0 0 0 0 0] 0;
scAlpha         scAlpha [0 0 0 0 0 0 0] 0;
phaseChangeCoeffs
{
    model          temperatureWindow;
    Tsolidus       1941;
    Tliquidus      1941;
    Tvapor         3560;
    windowWidth    50;
    onlyAboveMelt  true;
    onlyAboveVapor true;
    // ((start1 end1) (start2 end2) ...)
    // 214-fs pulse window from Nguyen (2022) Activation windows corresponding to each laser pulse
    activationTime ((0 2.14e-13));
}
massTransferCoeffs
{
    model     timeAndTemperatureWindow;
    tStart    (0);
    tEnd      (2.14e-13);    // 214 fs
    Tsolidus  1941;
    Tvapor    3560;
    rateMax   5e12;
}


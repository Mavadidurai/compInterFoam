FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phases (metal air);

metal
{
    transportModel  Newtonian;
    nu              nu [ 0 2 -1 0 0 0 0 ] 5e-7;
    rho             rho [ 1 -3 0 0 0 0 0 ] 4515;
}

air
{
    transportModel  Newtonian;
    nu              nu [ 0 2 -1 0 0 0 0 ] 1.48e-5;
    rho             rho [ 1 -3 0 0 0 0 0 ] 1.2;
}

meltingTemperature      meltingTemperature [0 0 0 1 0 0 0] 1941.0;
vaporTemperature        vaporTemperature [0 0 0 1 0 0 0] 3560.0;
latentHeat              latentHeat [0 2 -2 0 0 0 0] 3.65e5;

sigma           sigma [ 1 0 -2 0 0 0 0 ] 1.64;

cAlpha          cAlpha [0 0 0 0 0 0 0] 1;
icAlpha         icAlpha [0 0 0 0 0 0 0] 0;
scAlpha         scAlpha [0 0 0 0 0 0 0] 0;
phaseChangeCoeffs
{
    model          temperatureWindow;
    Tsolidus       1941;
    Tliquidus      1941;
    Tvapor         3560;
    windowWidth    50;
    onlyAboveMelt  true;
    onlyAboveVapor true;
    activationTime (2.5e-13 7.5e-13); // optional pulse window
}
massTransferCoeffs
{
    model     timeAndTemperatureWindow;
    tStart    2.5e-13;
    tEnd      7.5e-13;
    Tsolidus  1941;
    Tvapor    3560;
    rateMax   0;          // solver computes only inside the window
}

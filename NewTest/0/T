FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 300;     // thesis-style ambient start

boundaryField
{
  xMin     { type symmetryPlane; }
  xMax     { type symmetryPlane; }
  zMin     { type symmetryPlane; }
  zMax     { type symmetryPlane; }

  yMin     { type fixedValue; value uniform 300; }   // donor wall at ambient
  yMax     { type fixedValue; value uniform 300; }   // receiver wall at ambient
}




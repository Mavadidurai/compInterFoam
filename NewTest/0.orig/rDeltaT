FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      rDeltaT;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];    // 1/s

// dt floor = 1e-12 s  => rDeltaT = 1e12 1/s
internalField   uniform 1e12;

boundaryField
{
  xMin     { type symmetryPlane; }
  xMax     { type symmetryPlane; }
  zMin     { type symmetryPlane; }
  zMax     { type symmetryPlane; }

  yMin     { type zeroGradient; }
  yMax     { type zeroGradient; }
}


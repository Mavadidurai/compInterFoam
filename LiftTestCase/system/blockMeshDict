FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// ✅ REALISTIC LIFT GEOMETRY with substrate
// ==========================================
// Domain: 50μm × 20μm × 10μm (SAME total size)
// NEW Layout:
// - Substrate: Y = 0-8μm   (8μm thick glass substrate)
// - Metal:     Y = 8-10μm  (2μm thick metal film) 
// - Air:       Y = 10-20μm (10μm air gap for ejection)
//
// Cell distribution optimized for LIFT physics:
// - Substrate: 8 cells (1μm/cell) - adequate for heat conduction
// - Metal:     2 cells (1μm/cell) - fine resolution for thin film
// - Air:       10 cells (1μm/cell) - adequate for ejection tracking
// 
// Total: 25×20×10 = 5,000 cells (UNCHANGED computational load)

convertToMeters 1e-6; // Convert to micrometers

vertices
(
    (0    0   0)    // 0 - Bottom substrate corner
    (50   0   0)    // 1  
    (50  20   0)    // 2 - Top corner
    (0   20   0)    // 3
    (0    0  10)    // 4 - Bottom substrate corner (Z=10)
    (50   0  10)    // 5
    (50  20  10)    // 6 - Top corner (Z=10)
    (0   20  10)    // 7
);

blocks
(
    // ✅ SINGLE BLOCK - Same as before but different material assignment
    hex (0 1 2 3 4 5 6 7) (25 20 10) simpleGrading (1 1 1)
    
    // Cell distribution breakdown:
    // X: 25 cells × 2μm = 50μm width
    // Y: 20 cells × 1μm = 20μm height  
    //    - Cells 0-7:   Substrate (Y = 0-8μm)
    //    - Cells 8-9:   Metal film (Y = 8-10μm)  
    //    - Cells 10-19: Air gap (Y = 10-20μm)
    // Z: 10 cells × 1μm = 10μm depth
    //
    // Total: 5,000 cells (SAME as before)
);

edges
(
);

boundary
(
    top
    {
        type wall;
        faces
        (
            (4 7 6 5)
        );
    }
    
    // ✅ SUBSTRATE BOTTOM - Heat sink boundary
    bottom  
    {
        type wall;
        faces
        (
            (0 3 2 1)
        );
    }
    
    inlet
    {
        type wall;
        faces
        (
            (0 4 7 3)
        );
    }
    
    outlet
    {
        type wall;
        faces
        (
            (1 2 6 5) 
        );
    }
    
    front
    {
        type wall; 
        faces
        (
            (0 1 5 4)
        );
    }
    
    back
    {
        type wall;
        faces
        (
            (3 7 6 2)
        );
    }
);

mergePatchPairs
(
);


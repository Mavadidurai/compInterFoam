FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convertToMeters 1e-6; // coordinates in micrometers

vertices
(
    (0   0   0)   // 0
    (50  0   0)   // 1
    (50  20  0)   // 2
    (0   20  0)   // 3
    (0   0   10)  // 4
    (50  0   10)  // 5
    (50  20  10)  // 6
    (0   20  10)  // 7
);

blocks
(
    hex (0 1 2 3 4 5 6 7) (25 20 10) simpleGrading (1 1 1)
    // Y-layering intent:
    // 0–8 μm  : substrate (8 cells)
    // 8–10 μm : metal film (2 cells)
    // 10–20 μm: air gap (10 cells)
);

edges ();

boundary
(
    top
    {
        type wall;
        faces ((4 5 6 7));         // standard top ordering
    }
    bottom
    {
        type wall;
        faces ((0 1 2 3));         // standard bottom ordering
    }
    inlet
    {
        type wall;
        faces ((0 3 7 4));         // x=0 plane (standard ordering)
    }
    outlet
    {
        type wall;
        faces ((1 2 6 5));         // x=50 μm plane
    }
    front
    {
        type wall;
        faces ((0 1 5 4));         // z=0 plane
    }
    back
    {
        type wall;
        faces ((3 2 6 7));         // z=10 μm plane (standard ordering)
    }
);

mergePatchPairs ();

FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     compInterFoam;

startFrom       startTime;
startTime       0;

stopAt          endTime;
endTime         2e-3;          // cover flight/impact; tighten if you only want ultrafast stage

// Initial tiny Δt to resolve pulse front (≈ pulseWidth/50)
deltaT          1e-13;

adjustTimeStep  yes;
maxCo           0.2;
maxAlphaCo      0.2;
maxDeltaT       1e-7;

writeControl    runTime;
writeInterval   1e-11;         // dense output around the pulse; you can relax later
purgeWrite      0;

writeFormat     ascii;
writePrecision  10;
writeCompression off;
timeFormat      general;
timePrecision   12;

runTimeModifiable yes;

// ——— solver-specific switches your code actually reads ———
useAdvancedInterfaceCapturing  true;      // createFields.H -> constructs advancedInterfaceCapturing
enableTClamp                   true;      // TEqn.H: clamp T into [minT,maxT]
minT                           250;
maxT                           5000;

// pEqn.H safety bounds on rAUf
minRAUf                        1e-10;
maxRAUf                        1e6;

// Two-temperature model parameters (createFields.H passes this subDict to TTM)
twoTemperatureProperties
{
    Ce  2.0e6;      // J/m3/K
    Cl  3.0e6;      // J/m3/K
    G   2.0e16;     // W/m3/K
}

functions
{
    // Write laser source field (needed by your femtosecondLaserModel/Q_laser)
    QlaserWrite
    {
        type            writeObjects;
        libs            ("libutilityFunctionObjects.so");
        objects         (Q_laser);
        writeOnExecution true;
    }

    // High-frequency probes without heavy field dumps
    probesTTM
    {
        type            probes;
        libs            ("libsampling.so");
        fields          (Te Tl T p_rgh U alpha.metal);
        probeLocations
        (
            (0 0 0)          // in-film
            (0 0 2e-6)       // near interface
            (0 0 10e-6)      // mid-gap
        );
        writeControl    timeStep;
        writeInterval   10;
    }



    CourantNo
    {
        type            CourantNo;
        libs            ("libutilityFunctionObjects.so");
        writeControl    timeStep;
        writeInterval   1;
    }

    fieldMinMax_T
    {
        type            fieldMinMax;
        libs            ("libfieldFunctionObjects.so");
        writeControl    timeStep;
        writeInterval   1;
        fields (T);
    }

    fieldMinMax_alpha
    {
        type            fieldMinMax;
        libs            ("libfieldFunctionObjects.so");
        writeControl    timeStep;
        writeInterval   1;
        fields (alpha.metal);
    }


}

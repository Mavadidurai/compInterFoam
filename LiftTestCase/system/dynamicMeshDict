FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      dynamicMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// Enable automatic refinement/coarsening based on the
// interface gradient magnitude

dynamicFvMesh   dynamicRefineFvMesh;

dynamicRefineFvMeshCoeffs
{
    refineInterval      1;
    field               gradAlpha1Mag;
    lowerRefineLevel    0.1;
    upperRefineLevel    0.2;
    unrefineLevel       0.05;
    nBufferLayers       1;
    maxRefinement       2;
    maxCells            200000;
    correctFluxes       (phi alphaPhi10 rhoPhi);
    dumpLevel           true;
}


// ✅ REALISTIC LIFT FIELD INITIALIZATION with Substrate
// ======================================================
// NEW Geometry Layout:
// - Substrate: Y = 0-8μm   (Glass substrate - acts as solid boundary)
// - Metal:     Y = 8-10μm  (Titanium donor film - 2μm thick)  
// - Air:       Y = 10-20μm (Air gap for ejection)

defaultFieldValues
(
    // ✅ DEFAULT: Air everywhere initially
    volScalarFieldValue alpha.metal 0      // No metal by default
    volScalarFieldValue alpha.air 1        // Air everywhere by default
    volScalarFieldValue T 300              // Room temperature
    volScalarFieldValue Te 300             // Electron temperature at equilibrium
    volScalarFieldValue Tl 300             // Lattice temperature at equilibrium
    
    // ✅ NEW: Initialize velocities and pressure
    volVectorFieldValue U (0 0 0)          // Zero initial velocity
    volScalarFieldValue p_rgh 0            // Zero relative pressure
);

regions
(
    // ✅ REGION 1: SUBSTRATE (Y = 0-8μm)
    // ==================================
    // Substrate acts as a constrained boundary with thermal mass
    // Uses mixed phase approach to simulate solid behavior
    boxToCell
    {
        box (0 0 0) (50e-6 8e-6 10e-6);        // Bottom 8μm = substrate
        fieldValues
        (
            volScalarFieldValue alpha.metal 0.01    // Tiny metal fraction (substrate boundary)
            volScalarFieldValue alpha.air 0.99      // Mostly air (but constrained)
            volScalarFieldValue T 300               // Substrate at room temperature
            volScalarFieldValue Te 300              // No electron heating in substrate
            volScalarFieldValue Tl 300              // Substrate lattice temperature
            volVectorFieldValue U (0 0 0)           // Zero velocity (solid-like)
        );
    }
    
    // ✅ REGION 2: METAL DONOR FILM (Y = 8-10μm) 
    // ===========================================
    // Titanium film - the core LIFT material
    boxToCell
    {
        box (0 8e-6 0) (50e-6 10e-6 10e-6);       // 2μm thick metal film
        fieldValues
        (
            volScalarFieldValue alpha.metal 1       // Pure metal phase
            volScalarFieldValue alpha.air 0         // No air in metal
            volScalarFieldValue T 300               // Metal at room temperature initially
            volScalarFieldValue Te 300              // Electron temp at equilibrium
            volScalarFieldValue Tl 300              // Lattice temp at equilibrium
            volVectorFieldValue U (0 0 0)           // Zero initial velocity
        );
    }
    
    // ✅ REGION 3: AIR GAP (Y = 10-20μm)
    // ===================================
    // Air space for droplet ejection and collection
    // Uses default values (already set above)
    // No explicit region needed - covered by defaults
    
    // ✅ OPTIONAL: LASER FOCAL ZONE MARKER
    // ====================================
    // Mark the laser focal region for visualization/debugging
    boxToCell
    {
        box (20e-6 8.5e-6 4e-6) (30e-6 9.5e-6 6e-6);  // Small region at laser focus
        fieldValues
        (
            // Keep material properties but mark with slightly different temperature
            volScalarFieldValue T 301               // 1K higher for identification
        );
    }
);


FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      laserProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //


// Gaussian pulse focused in the 2 µm metal film (y=8–10 µm)
// Domain: x∈[0,50e-6], y∈[0,20e-6], z∈[0,10e-6]

laserModel      gaussian;

// --- Energy & timing (choose microsecond pulse as you indicated) ---
pulseEnergy     1e-6;         // [J] total energy
energy          1e-6;         // [J] keep equal if both are read by the model

pulseWidth      1e-6;         // [s] 1 µs pulse width
pulseDuration   1e-6;         // [s] keep equal to avoid conflicts
laserStartTime  0;            // [s]
laserEndTime    1e-6;         // [s] = start + pulseWidth

// --- Spatial Gaussian (match the box center and film depth) ---
spotRadius      5e-6;         // [m] beam radius (5 µm)
spotSize        5e-6;         // [m] keep consistent if the code uses this name

// Put the beam center inside the domain (mid x,z; inside metal at y≈9 µm)
center          (25e-6 9e-6 5e-6);
focus           (25e-6 9e-6 5e-6);
direction       (0 1 0);

// --- Wavelength / interaction ---
wavelength          1.03e-6;  // [m]

// Absorption: make depth consistent with coefficient (~20 nm)
absorptionCoeff     5e7;      // [1/m]
absorptionDepth     20e-9;    // [m] (≈1/absorptionCoeff)

// Reflectivity / profile
reflectivity        0.3;
gaussianProfile     true;
maxReflections      1;

// Optional intensity entry (keep but consistent with chosen pulse width)
peakIntensity       1e8;      // [W/m^2] (not strictly needed if model uses energy)
continuousLaser     false;
// ************************************************************************* //

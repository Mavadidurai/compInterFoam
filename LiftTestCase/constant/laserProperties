FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      laserProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// MILLISECOND-SCALE LASER (Instantaneous energy deposition)
laserModel      gaussian;
energy          1e-6;        // [J]
pulseDuration   1e-9;        // [s]
spotRadius      25e-6;       // [m]
center          (5e-4 0 0);
absorptionDepth 10e-9;       // [m]
// Power settings - total energy deposited instantly
peakIntensity       1e8;           // Lower intensity, longer pulse
pulseWidth          1e-6;         // 100 microsecond "pulse" 
wavelength          1.03e-6;         // Ti:Sapphire wavelength
spotSize            5e-6;           // 5 μm spot - same as before
pulseEnergy         1e-6;          // 10 nJ total energy

// Geometry - same as before
focus               (25e-6 9e-6 5e-6);    
direction           (0 1 0);              

// Material interaction - same physics
absorptionCoeff     5e7;            
reflectivity        0.3;            
gaussianProfile     true;           
maxReflections      1;              

// TIMING FOR MILLISECOND SCALE
continuousLaser     false;          
laserStartTime      0;              // Start immediately
laserEndTime        2e-6;         // 100 microsecond pulse

// This gives stable, predictable energy deposition over 100 μs
// Much easier than femtosecond precision!

// ************************************************************************* //

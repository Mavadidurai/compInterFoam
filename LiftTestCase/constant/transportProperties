FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// ✅ ENHANCED: Three-phase transport properties for realistic LIFT
// Note: Using two-phase approach but with substrate effects in boundary conditions

phases (metal air);

// ✅ METAL PHASE: Titanium donor film properties
metal
{
    transportModel  Newtonian;
    nu              nu [ 0 2 -1 0 0 0 0 ] 5e-7;     // ✅ OPTIMIZED: Higher viscosity for stability
    rho             rho [ 1 -3 0 0 0 0 0 ] 4500;     // Titanium density
}

// ✅ AIR PHASE: Includes substrate simulation in lower region
air
{
    transportModel  Newtonian;
    nu              nu [ 0 2 -1 0 0 0 0 ] 1.48e-5;   // Air kinematic viscosity  
    rho             rho [ 1 -3 0 0 0 0 0 ] 1.2;       // Air density (substrate simulated via BC)
}

// ✅ ENHANCED: Phase change properties for LIFT with substrate effects
meltingTemperature      1941.0;     // K - Titanium melting point
vaporTemperature        3560.0;     // K - Titanium vaporization point  
latentHeat              435e3;      // J/kg - Titanium latent heat of fusion

// ✅ NEW: Substrate thermal properties (for boundary conditions)
substrateProperties
{
    // Glass substrate thermal characteristics
    thermalConductivity     1.3;        // W/m/K - Glass thermal conductivity
    heatCapacity           840;         // J/kg/K - Glass specific heat
    density               2500;         // kg/m³ - Glass density
    thermalDiffusivity    6.2e-7;      // m²/s - Glass thermal diffusivity
    
    // Interface properties
    interfaceThermalResistance  1e-8;   // m²K/W - Substrate/metal interface
    interfaceRoughness         1e-9;    // m - Surface roughness
}

// ✅ ENHANCED: Surface tension between phases (including substrate effects)
sigma           sigma [ 1 0 -2 0 0 0 0 ] 1.5;         // N/m - Metal-air surface tension

// ✅ NEW: Substrate-metal interface tension (affects wetting)
sigmaSM         sigmaSM [ 1 0 -2 0 0 0 0 ] 2.0;       // N/m - Substrate-metal interface
contactAngle    120;                                   // degrees - Contact angle on substrate

// ✅ OPTIMIZED: Interface compression for substrate system
cAlpha          0.5;        // ✅ REDUCED: Less aggressive for stability with substrate
icAlpha         0;          // Isotropic compression (disabled)
scAlpha         0;          // Shear compression (disabled)

// ✅ NEW: LIFT-specific transport parameters
liftParameters
{
    // Ejection characteristics
    ejectionVelocityScale   100;        // m/s - Typical LIFT ejection velocity
    dropletSizeScale        1e-6;       // m - Typical droplet size
    
    // Thermal transport enhancement at interface
    interfaceEnhancement    2.0;        // Enhancement factor for interface transport
    
    // Substrate constraint effects
    substrateConstraintFactor  0.1;     // Fraction of motion allowed in substrate region
    
    // Phase change enhancement
    nucleationSites         1e12;       // sites/m² - Nucleation site density
    superheatingLimit       500;        // K - Maximum superheat before nucleation
}

// ✅ ENHANCED: Temperature-dependent properties
temperatureDependence
{
    // Metal viscosity temperature dependence
    metalViscosityModel     "Arrhenius";
    metalViscosityCoeffs
    {
        mu0     1e-3;       // Pa·s - Reference viscosity
        E       20000;      // J/mol - Activation energy
        Tref    1941;       // K - Reference temperature
    }
    
    // Surface tension temperature dependence  
    sigmaTempCoeff  -2e-4;              // N/m/K - Temperature coefficient
}

// ************************************************************************* //

FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      refineMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
// Keep the focusBox cellSet for debugging, but all refinement is now handled
// directly in blockMesh.  refineMesh therefore behaves as a pass-through copy.
set                 focusBox;
coordinateSystem    global;
globalCoeffs
{
    tan1   (1 0 0);   // x-direction
    tan2   (0 0 1);   // z-direction
    normal (0 1 0);   // y-direction (film thickness)
}

// BlockMesh now resolves the Ti film thickness, so keep refineMesh as a
// pass-through to avoid reintroducing ultra-thin slices.
directions           (normal);

useHexTopology      no;
geometricCut        no;              // ensure no geometric splitting occurs
writeMesh           no;

nBufferLayers        0;
maxGlobalCells       30000000;
maxLocalCells        30000000;
minRefinementCells   0;

refinementRegions
{
    donorFilmBox
    {
        mode inside;
        levels ((1e15 0));
        box
        {
            min (0 19.99 0);
            max (50 20.0814 10);
        }
    }
}

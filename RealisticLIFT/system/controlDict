FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     compInterFoam;

startFrom       latestTime;
startTime       0;
stopAt          endTime;
endTime         2e-9;           // Observation window through plume relaxation

deltaT          2e-16;         // Base time step (0.2 fs)
adjustTimeStep  yes;           // Enable adaptive time stepping
maxCo           0.02;          // Kept conservative for micron cells
maxAlphaCo      0.005;
maxDeltaT       1e-15;
minDeltaT       5e-17;

verbose         true;
thermalFluxRelax 0.15;         // Moderate damping per fs LIFT fits
maxThermalCourant 0.01;        // Allow realistic electron-lattice steps

// ADAPTIVE OUTPUT - more frequent during active phase, less during cooling
writeControl    adjustableRunTime;
writeInterval   1e-15;         // 0.2 ps intervals capture plume rise without flooding disk
purgeWrite      100;            // Keep more time directories for analysis
writeFormat     ascii;
writePrecision  8;
writeCompression off;
timeFormat      general;
timePrecision   8;             // Increased precision for longer runs
fileHandler     uncollated;

runTimeModifiable yes;
enableLiftProcessTracker true;

// EXTENDED PHASE-CHANGE - longer activation for complete process
phaseChangeCoeffs
{
    model               clausius_clapeyron;  // Not temperature window!
    hf                  [0 2 -2 0 0 0 0] 9.1e6;   // J/kg (Ti vaporisation)
    gasConstant         [0 2 -2 -1 0 0 0] 174;    // J/kg/K (Ti vapor)
    Tsol                [0 0 0 1 0 0 0] 1941;     // K
    Tvap                [0 0 0 1 0 0 0] 3560;     // K
    
    // Kinetic theory parameters
    evaporationCoeff       0.03;     // Ti evaporation coefficient
    momentumAccom       0.18;     // Momentum accommodation
    
    //windowWidth         100;
    dtFloor             1e-15;         // Reduced for precision
    relaxationTime      5e-12;        // Faster response for femtosecond dynamics
    // Permit the Clausius–Clapeyron source to match the absorbed 0.2 J/cm^2 pulse (Piqué et al., Appl. Phys. A 79, 2004)
    maxSource           [1 -1 -3 0 0 0 0] 1e22;
    minCoefficient      [1 -1 -3 0 0 0 0] 5e21;
    onlyAboveVapor      false;
    metalFractionCutoff 1e-6;
    // EXTENDED ACTIVATION - through transfer and cooling
    activationTime      ((0 4e-10));  // Active through 400 ps as intended
}

// EXTENDED MASS TRANSFER - through solidification
massTransferCoeffs
{
    tStart  (0);
    tEnd    (4e-10);   // Active through 400 ps
    rateMax 3e13;      // Needed to ablate the 70 nm Ti film within ~200 ps (Piqué et al., Appl. Phys. A 79, 2004)
}

// LASER TIMING - shorter pulse, longer observation
laserStartTime      0;
laserEndTime    2e-10;

// Advanced interface capturing - TUNED FOR EXTENDED SIMULATION
useAdvancedInterfaceCapturing  true;
advancedInterfaceCapturing
{
    model               kinetic_theory;  // Not arbitrary scaling!
    stickingCoeff       0.03;
    momentumAccom       0.18;
    recoilMax             8e7;      // 80 MPa upper bound (fs Ti LIFT measurements)
    clampRecoil           true;
    scaleRecoilMax        false;    // ✅ DISABLE scaling (let physics control it)
    recoilTempOffset      0;        // Activate recoil exactly at Tvap (Phipps et al., J. Appl. Phys. 2017)
    phaseChangeTempOffset 0;        // Activate phase change at Tvap (Phipps et al., J. Appl. Phys. 2017)
    recoilRelax           0.3;      // ✅ INCREASE from 0.1 (more damping)
    alphaMin              0.01;
    alphaMax              1;
    maxPhysicalTemperature 10000;
    // Physical limits
    maxRecoilPressure   8e7;    // 80 MPa absolute max (Papazoglou 2002; Feinaeugle 2017)
}
logRecoilSuppression true;

// Temperature clamping - EXTENDED RANGE
enableTClamp    false;
minT            200;           // Allow cooling below room temp
maxT            10000;          // Keep within measured Ti plume temperatures (~10 kK)

// Two-temperature model properties - OPTIMIZED FOR EXTENDED RUNS
twoTemperatureProperties
{
    
    // Linear electronic heat capacity: Ce = γTe
    Ce
    {
        type        polynomial;
        value       0;
        coeffs
        (
            (0   0)  // Constant term = 0
            (630 1)  // Linear term: Ce = 630 · Te [J/m³/K²]
        );
    }
    
    // Temperature-dependent coupling (Lin & Zhigilei, Phys. Rev. B 77, 2008)
    G
    {
        type        table;
        values
        (
            (300     2.4e17)
            (1000    2.7e17)
            (2000    3.2e17)
            (5000    3.9e17)
            (10000   4.5e17)
            (15000   4.8e17)
            (20000   5.0e17)
        );
    }

    Cl  [1 -1 -2 -1 0 0 0] 2.5e6;
    De  [0  2 -1  0 0 0 0] 5e-5;

    gasMetalExchangeCoeff
    {
        type        kapitza;    // Use acoustic mismatch model
        Z_metal     2.3e7;      // Ti acoustic impedance [Pa·s/m]
        Z_gas       383;        // Ar acoustic impedance [Pa·s/m]
        rho_metal   4500;       // Ti density [kg/m^3]
        rho_gas     1.7;        // Ar density [kg/m^3]
    }
    gasMetalCutoffTemperature 3560;   // Disable Kapitza coupling once Ti reaches Tvap (Piqué et al., Appl. Phys. A 79, 2004)
    minMetalFractionForExchange 0.5;  // Require ≥50% metal volume fraction before coupling to gas plume
    minGasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 0;
    // Kapitza conduction across a ~50 nm interface at 5–6 kK yields
    // volumetric couplings O(1e17) W/m^3/K (Swartz & Pohl 1989), so keep the
    // limiter comfortably above that to avoid choking the physics.
    maxGasMetalExchangeCoeff [1 -1 -3 -1 0 0 0] 1e18;
    maxGasMetalHeatFlux    5e7;   // Surface heat flux cap [W/m²]
    
    // ✅ ADJUSTED: Allow higher lattice temperatures now that coupling works
    minTe           200;
    maxTe           18000;      // Electron temperatures measured in fs plumes stay < 18 kK
    maxTl           9000;       // Lattice temperatures peak around 8–9 kK
    ambientTemperature 300;
    temperatureDifferenceFloor 10.0;                     // Guard against Te/Tl collapse
    
    // ADAPTIVE MICRO-STEPPING
    electronSubCycles        20;
    minElectronSubCycles     10;
    maxElectronSubCycles     50;     // Allow rapid transients
    maxElectronDeltaT        [0 0 1 0 0 0 0] 1e-15;  // Guard rapid transients

    nInnerCouplingSweeps         3;  // More coupling iterations
    innerCouplingResidualTol     1e-4; // Enable convergence check
    
    klHighTThreshold 1000;
    klExponent       0.5;

    metalFractionFloor      1e-6;
    metalFractionCutoff     1e-6;
    metalAmbientBlendWidth  1e-3;
    CvolGasFloor    1e6;  // J/m^3/K floor for gas cells

    energyTolerance         0.05;    // Relaxed for long runs
    energyDiagnostics       true;
    temperatureDiagnostics  true;   // Reduce output volume
    energyAudit             true;
}

// Clean monitoring functions
functions
{
    // Mid-plane visualization (optional)
    midPlaneVTK
    {
        type            surfaces;
        libs            ("libsampling.so");
        writeControl    writeTime;
        writeInterval   1;
        surfaceFormat   vtk;
        fields          (alpha.metal Tl Te T p_rgh U);

        surfaces
        (
            midPlane
            {
                type                cuttingPlane;
                planeType           pointAndNormal;
                pointAndNormalDict
                {
                    point   (25e-6 2.00357e-05 5e-6);
                    normal  (0 1 0);
                }
                interpolate         true;
            }
        );
    }
}
